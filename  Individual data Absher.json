{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/absher-individual-basic-info.schema.json",
  "title": "Absher Individual Basic Information",
  "description": "Basic information typically stored for an individual in an Absher-like profile model. This is a generic technical schema, not an official Absher specification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "personId",
    "personType",
    "fullNameArabic",
    "dateOfBirthGregorian",
    "nationality",
    "mobileNumber",
    "email",
    "status"
  ],
  "properties": {
    "personId": {
      "type": "string",
      "title": "Person Identifier",
      "description": "Saudi national ID or iqama number.",
      "pattern": "^[12]\\d{9}$",
      "minLength": 10,
      "maxLength": 10,
      "examples": ["1023456789"],
      "x-format-note": "Exactly 10 digits, starts with 1 or 2."
    },
    "personType": {
      "type": "string",
      "title": "Person Type",
      "enum": [
        "saudi_citizen",
        "resident",
        "gcc_citizen",
        "visitor",
        "other"
      ],
      "examples": ["saudi_citizen"]
    },
    "fullNameArabic": {
      "type": "string",
      "title": "Full Name in Arabic",
      "minLength": 2,
      "maxLength": 200,
      "examples": ["أحمد محمد القحطاني"]
    },
    "fullNameEnglish": {
      "type": "string",
      "title": "Full Name in English",
      "minLength": 2,
      "maxLength": 200,
      "examples": ["Ahmed Mohammed Al-Qahtani"]
    },
    "firstNameArabic": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "examples": ["أحمد"]
    },
    "fatherNameArabic": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "examples": ["محمد"]
    },
    "grandfatherNameArabic": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "examples": ["عبدالله"]
    },
    "familyNameArabic": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "examples": ["القحطاني"]
    },
    "gender": {
      "type": "string",
      "enum": [
        "male",
        "female"
      ],
      "examples": ["male"]
    },
    "dateOfBirthGregorian": {
      "type": "string",
      "format": "date",
      "examples": ["1990-05-14"]
    },
    "dateOfBirthHijri": {
      "type": "string",
      "description": "Hijri date as text in YYYY-MM-DD style if stored separately.",
      "pattern": "^1\\d{3}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])$",
      "examples": ["1410-10-19"]
    },
    "nationality": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100,
      "examples": ["Saudi Arabian"]
    },
    "nationalityCode": {
      "type": "string",
      "description": "ISO-style or internal nationality code.",
      "minLength": 2,
      "maxLength": 3,
      "pattern": "^[A-Z]{2,3}$",
      "examples": ["SA"]
    },
    "maritalStatus": {
      "type": "string",
      "enum": [
        "single",
        "married",
        "divorced",
        "widowed",
        "unknown"
      ],
      "examples": ["married"]
    },
    "mobileNumber": {
      "type": "string",
      "description": "Saudi mobile number in local format.",
      "pattern": "^05\\d{8}$",
      "examples": ["0551234567"],
      "x-format-note": "10 digits, starts with 05."
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 254,
      "examples": ["user@example.sa"]
    },
    "profilePhotoId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "examples": ["photo_938475"]
    },
    "preferredLanguage": {
      "type": "string",
      "enum": [
        "ar",
        "en"
      ],
      "examples": ["ar"]
    },
    "nationalAddress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "region": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "examples": ["Riyadh Region"]
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "examples": ["Riyadh"]
        },
        "district": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "examples": ["Al Malqa"]
        },
        "streetName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 150,
          "examples": ["Anas Ibn Malik Road"]
        },
        "buildingNumber": {
          "type": "string",
          "pattern": "^\\d{4}$",
          "examples": ["1234"],
          "x-format-note": "4 digits."
        },
        "postalCode": {
          "type": "string",
          "pattern": "^\\d{5}$",
          "examples": ["13521"]
        },
        "additionalNumber": {
          "type": "string",
          "pattern": "^\\d{4}$",
          "examples": ["6789"]
        },
        "unitNumber": {
          "type": "string",
          "pattern": "^\\d{1,10}$",
          "examples": ["12"]
        },
        "shortAddress": {
          "type": "string",
          "pattern": "^[A-Z]{4}\\d{4}$",
          "examples": ["ABCD1234"],
          "x-format-note": "4 uppercase letters followed by 4 digits."
        }
      }
    },
    "documentInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "documentType": {
          "type": "string",
          "enum": [
            "national_id",
            "iqama",
            "passport",
            "gcc_id",
            "other"
          ],
          "examples": ["national_id"]
        },
        "documentNumber": {
          "type": "string",
          "minLength": 3,
          "maxLength": 30,
          "examples": ["1023456789"]
        },
        "issueDate": {
          "type": "string",
          "format": "date",
          "examples": ["2024-01-10"]
        },
        "expiryDate": {
          "type": "string",
          "format": "date",
          "examples": ["2034-01-09"]
        },
        "issuingAuthority": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "examples": ["Civil Affairs"]
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "suspended",
        "deceased",
        "unknown"
      ],
      "examples": ["active"]
    },
    "twoFactorEnabled": {
      "type": "boolean",
      "examples": [true]
    },
    "lastLoginAt": {
      "type": "string",
      "format": "date-time",
      "examples": ["2026-03-07T09:15:00Z"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "examples": ["2024-06-01T12:00:00Z"]
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "examples": ["2026-03-07T09:20:00Z"]
    }
  }
}