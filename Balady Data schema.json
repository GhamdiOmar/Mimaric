{
  "property": {
    "propertyId": {
      "type": "string",
      "required": true,
      "description": "Unique internal property identifier in Balady or the municipal system.",
      "constraints": {
        "minLength": 1,
        "maxLength": 50,
        "pattern": "^[A-Za-z0-9\\-_/]+$",
        "example": "BAL-PROP-2026-000123"
      }
    },
    "parcelNumber": {
      "type": "string",
      "required": true,
      "description": "Official parcel number for the land plot.",
      "constraints": {
        "minLength": 1,
        "maxLength": 30,
        "pattern": "^[A-Za-z0-9\\-/]+$",
        "example": "P-2458-17"
      }
    },
    "plotNumber": {
      "type": "string",
      "required": false,
      "description": "Plot number within the approved subdivision plan.",
      "constraints": {
        "minLength": 1,
        "maxLength": 20,
        "pattern": "^[A-Za-z0-9\\-/]+$",
        "example": "117"
      }
    },
    "blockNumber": {
      "type": "string",
      "required": false,
      "description": "Block number in the district or subdivision plan.",
      "constraints": {
        "minLength": 1,
        "maxLength": 20,
        "pattern": "^[A-Za-z0-9\\-/]+$",
        "example": "B12"
      }
    },
    "deedNumber": {
      "type": "string",
      "required": false,
      "description": "Title deed number issued by the relevant authority.",
      "constraints": {
        "minLength": 5,
        "maxLength": 50,
        "pattern": "^[A-Za-z0-9\\-/]+$",
        "example": "DEED-1445-998877"
      }
    },
    "propertyType": {
      "type": "string",
      "required": true,
      "description": "General category of the property.",
      "constraints": {
        "enum": [
          "residential",
          "commercial",
          "industrial",
          "agricultural",
          "mixed_use",
          "governmental",
          "other"
        ],
        "example": "residential"
      }
    },
    "landUse": {
      "type": "string",
      "required": true,
      "description": "Approved zoning or land use classification.",
      "constraints": {
        "enum": [
          "residential",
          "commercial",
          "industrial",
          "agricultural",
          "administrative",
          "public_facility",
          "mixed_use",
          "other"
        ],
        "example": "residential"
      }
    },
    "areaSqm": {
      "type": "number",
      "required": true,
      "description": "Land area in square meters.",
      "constraints": {
        "minimum": 1,
        "maximum": 10000000,
        "precision": 2,
        "example": 750.5
      }
    },
    "address": {
      "type": "object",
      "required": true,
      "description": "Structured address details for the property.",
      "properties": {
        "region": {
          "type": "string",
          "required": true,
          "constraints": {
            "minLength": 2,
            "maxLength": 100,
            "example": "Riyadh Region"
          }
        },
        "city": {
          "type": "string",
          "required": true,
          "constraints": {
            "minLength": 2,
            "maxLength": 100,
            "example": "Riyadh"
          }
        },
        "municipality": {
          "type": "string",
          "required": false,
          "constraints": {
            "minLength": 2,
            "maxLength": 100,
            "example": "Al Olaya Municipality"
          }
        },
        "district": {
          "type": "string",
          "required": true,
          "constraints": {
            "minLength": 2,
            "maxLength": 100,
            "example": "Al Olaya"
          }
        },
        "streetName": {
          "type": "string",
          "required": false,
          "constraints": {
            "minLength": 2,
            "maxLength": 150,
            "example": "King Fahd Road"
          }
        },
        "buildingNumber": {
          "type": "string",
          "required": false,
          "constraints": {
            "pattern": "^\\d{4}$",
            "description": "Saudi national address building number is typically 4 digits.",
            "example": "1234"
          }
        },
        "postalCode": {
          "type": "string",
          "required": false,
          "constraints": {
            "pattern": "^\\d{5}$",
            "description": "Saudi postal code is 5 digits.",
            "example": "12211"
          }
        },
        "additionalNumber": {
          "type": "string",
          "required": false,
          "constraints": {
            "pattern": "^\\d{4}$",
            "description": "Saudi national address additional number is typically 4 digits.",
            "example": "6789"
          }
        },
        "shortAddress": {
          "type": "string",
          "required": false,
          "constraints": {
            "pattern": "^[A-Z]{4}\\d{4}$",
            "description": "Saudi short address is commonly 4 uppercase letters followed by 4 digits.",
            "example": "RRAA1234"
          }
        }
      }
    },
    "coordinates": {
      "type": "object",
      "required": true,
      "description": "Geographic coordinates of the property centroid or entrance.",
      "properties": {
        "latitude": {
          "type": "number",
          "required": true,
          "constraints": {
            "minimum": -90,
            "maximum": 90,
            "precision": 6,
            "example": 24.713551
          }
        },
        "longitude": {
          "type": "number",
          "required": true,
          "constraints": {
            "minimum": -180,
            "maximum": 180,
            "precision": 6,
            "example": 46.675296
          }
        }
      }
    },
    "boundaries": {
      "type": "object",
      "required": false,
      "description": "Property boundary details by direction.",
      "properties": {
        "north": {
          "type": "string",
          "required": false,
          "constraints": {
            "maxLength": 200,
            "example": "12m street"
          }
        },
        "south": {
          "type": "string",
          "required": false,
          "constraints": {
            "maxLength": 200,
            "example": "Neighboring parcel 2459"
          }
        },
        "east": {
          "type": "string",
          "required": false,
          "constraints": {
            "maxLength": 200,
            "example": "Service lane"
          }
        },
        "west": {
          "type": "string",
          "required": false,
          "constraints": {
            "maxLength": 200,
            "example": "Neighboring parcel 2457"
          }
        }
      }
    },
    "owner": {
      "type": "object",
      "required": true,
      "description": "Primary owner information.",
      "properties": {
        "ownerType": {
          "type": "string",
          "required": true,
          "constraints": {
            "enum": [
              "individual",
              "company",
              "government",
              "charity",
              "other"
            ],
            "example": "individual"
          }
        },
        "ownerName": {
          "type": "string",
          "required": true,
          "constraints": {
            "minLength": 2,
            "maxLength": 200,
            "example": "Ahmed Mohammed Al-Qahtani"
          }
        },
        "nationalId": {
          "type": "string",
          "required": false,
          "description": "Saudi national ID / iqama for an individual owner.",
          "constraints": {
            "pattern": "^[12]\\d{9}$",
            "descriptionDetailed": "Must be exactly 10 digits and start with 1 or 2.",
            "example": "1023456789"
          }
        },
        "commercialRegistrationNumber": {
          "type": "string",
          "required": false,
          "description": "Commercial registration number for a company owner.",
          "constraints": {
            "pattern": "^\\d{10}$",
            "descriptionDetailed": "Typically 10 digits.",
            "example": "1010123456"
          }
        },
        "mobileNumber": {
          "type": "string",
          "required": false,
          "constraints": {
            "pattern": "^05\\d{8}$",
            "description": "Saudi mobile number in local format, 10 digits starting with 05.",
            "example": "0551234567"
          }
        },
        "email": {
          "type": "string",
          "required": false,
          "constraints": {
            "format": "email",
            "maxLength": 254,
            "example": "owner@example.sa"
          }
        }
      }
    },
    "coOwners": {
      "type": "array",
      "required": false,
      "description": "Additional co-owners of the property.",
      "constraints": {
        "maxItems": 20
      },
      "items": {
        "type": "object",
        "properties": {
          "ownerName": {
            "type": "string",
            "required": true,
            "constraints": {
              "minLength": 2,
              "maxLength": 200
            }
          },
          "nationalId": {
            "type": "string",
            "required": false,
            "constraints": {
              "pattern": "^[12]\\d{9}$",
              "descriptionDetailed": "Must be exactly 10 digits and start with 1 or 2."
            }
          },
          "sharePercentage": {
            "type": "number",
            "required": true,
            "constraints": {
              "minimum": 0.01,
              "maximum": 100,
              "precision": 2,
              "example": 50
            }
          }
        }
      }
    },
    "buildingDetails": {
      "type": "object",
      "required": false,
      "description": "Physical building information where applicable.",
      "properties": {
        "hasBuilding": {
          "type": "boolean",
          "required": true,
          "example": true
        },
        "numberOfBuildings": {
          "type": "integer",
          "required": false,
          "constraints": {
            "minimum": 0,
            "maximum": 100,
            "example": 1
          }
        },
        "numberOfUnits": {
          "type": "integer",
          "required": false,
          "constraints": {
            "minimum": 0,
            "maximum": 10000,
            "example": 4
          }
        },
        "numberOfFloors": {
          "type": "integer",
          "required": false,
          "constraints": {
            "minimum": 0,
            "maximum": 200,
            "example": 2
          }
        },
        "buildingAreaSqm": {
          "type": "number",
          "required": false,
          "constraints": {
            "minimum": 0,
            "maximum": 10000000,
            "precision": 2,
            "example": 420.75
          }
        },
        "constructionYearHijri": {
          "type": "integer",
          "required": false,
          "constraints": {
            "minimum": 1300,
            "maximum": 1600,
            "example": 1442
          }
        }
      }
    },
    "permits": {
      "type": "array",
      "required": false,
      "description": "Building or municipal permits linked to the property.",
      "constraints": {
        "maxItems": 100
      },
      "items": {
        "type": "object",
        "properties": {
          "permitNumber": {
            "type": "string",
            "required": true,
            "constraints": {
              "minLength": 5,
              "maxLength": 50,
              "pattern": "^[A-Za-z0-9\\-/]+$",
              "example": "BP-2025-00991"
            }
          },
          "permitType": {
            "type": "string",
            "required": true,
            "constraints": {
              "enum": [
                "building_permit",
                "renovation_permit",
                "demolition_permit",
                "fence_permit",
                "occupancy_certificate",
                "other"
              ],
              "example": "building_permit"
            }
          },
          "issueDate": {
            "type": "string",
            "required": true,
            "constraints": {
              "format": "date",
              "example": "2025-01-15"
            }
          },
          "expiryDate": {
            "type": "string",
            "required": false,
            "constraints": {
              "format": "date",
              "example": "2026-01-14"
            }
          },
          "status": {
            "type": "string",
            "required": true,
            "constraints": {
              "enum": [
                "active",
                "expired",
                "cancelled",
                "completed",
                "suspended"
              ],
              "example": "active"
            }
          }
        }
      }
    },
    "occupancyStatus": {
      "type": "string",
      "required": false,
      "description": "Current occupancy state of the property.",
      "constraints": {
        "enum": [
          "vacant",
          "owner_occupied",
          "tenant_occupied",
          "under_construction",
          "partially_occupied",
          "unknown"
        ],
        "example": "owner_occupied"
      }
    },
    "utilities": {
      "type": "object",
      "required": false,
      "description": "Availability of utility connections.",
      "properties": {
        "electricityConnected": {
          "type": "boolean",
          "required": false,
          "example": true
        },
        "waterConnected": {
          "type": "boolean",
          "required": false,
          "example": true
        },
        "sewageConnected": {
          "type": "boolean",
          "required": false,
          "example": true
        },
        "roadAccess": {
          "type": "boolean",
          "required": false,
          "example": true
        }
      }
    },
    "valuation": {
      "type": "object",
      "required": false,
      "description": "Estimated property valuation and charges.",
      "properties": {
        "estimatedValueSar": {
          "type": "number",
          "required": false,
          "constraints": {
            "minimum": 0,
            "maximum": 100000000000,
            "precision": 2,
            "example": 1250000
          }
        },
        "annualMunicipalFeesSar": {
          "type": "number",
          "required": false,
          "constraints": {
            "minimum": 0,
            "maximum": 100000000,
            "precision": 2,
            "example": 5000
          }
        }
      }
    },
    "violations": {
      "type": "array",
      "required": false,
      "description": "Municipal violations registered against the property.",
      "constraints": {
        "maxItems": 1000
      },
      "items": {
        "type": "object",
        "properties": {
          "violationNumber": {
            "type": "string",
            "required": true,
            "constraints": {
              "minLength": 1,
              "maxLength": 50,
              "pattern": "^[A-Za-z0-9\\-/]+$",
              "example": "VIO-2025-0011"
            }
          },
          "violationType": {
            "type": "string",
            "required": true,
            "constraints": {
              "maxLength": 100,
              "example": "building_without_permit"
            }
          },
          "fineAmountSar": {
            "type": "number",
            "required": false,
            "constraints": {
              "minimum": 0,
              "maximum": 100000000,
              "precision": 2,
              "example": 10000
            }
          },
          "status": {
            "type": "string",
            "required": true,
            "constraints": {
              "enum": [
                "open",
                "paid",
                "cancelled",
                "under_review"
              ],
              "example": "open"
            }
          }
        }
      }
    },
    "attachments": {
      "type": "array",
      "required": false,
      "description": "Documents and files attached to the property record.",
      "constraints": {
        "maxItems": 200
      },
      "items": {
        "type": "object",
        "properties": {
          "documentType": {
            "type": "string",
            "required": true,
            "constraints": {
              "enum": [
                "title_deed",
                "survey_plan",
                "building_drawings",
                "photo",
                "completion_certificate",
                "permit_copy",
                "other"
              ],
              "example": "title_deed"
            }
          },
          "fileName": {
            "type": "string",
            "required": true,
            "constraints": {
              "maxLength": 255,
              "example": "title-deed.pdf"
            }
          },
          "fileFormat": {
            "type": "string",
            "required": true,
            "constraints": {
              "enum": [
                "pdf",
                "jpg",
                "jpeg",
                "png",
                "dwg",
                "doc",
                "docx"
              ],
              "example": "pdf"
            }
          },
          "fileSizeMb": {
            "type": "number",
            "required": false,
            "constraints": {
              "minimum": 0,
              "maximum": 100,
              "precision": 2,
              "example": 2.45
            }
          }
        }
      }
    },
    "audit": {
      "type": "object",
      "required": false,
      "description": "Record creation and update metadata.",
      "properties": {
        "createdAt": {
          "type": "string",
          "required": true,
          "constraints": {
            "format": "date-time",
            "example": "2026-03-07T10:30:00Z"
          }
        },
        "updatedAt": {
          "type": "string",
          "required": true,
          "constraints": {
            "format": "date-time",
            "example": "2026-03-07T12:15:00Z"
          }
        },
        "createdBy": {
          "type": "string",
          "required": false,
          "constraints": {
            "maxLength": 100,
            "example": "balady_admin"
          }
        },
        "updatedBy": {
          "type": "string",
          "required": false,
          "constraints": {
            "maxLength": 100,
            "example": "municipality_user_01"
          }
        }
      }
    }
  }
}