{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/moc-cr-entity-basic-info.schema.json",
  "title": "Ministry of Commerce CR Entity Basic Information",
  "description": "Generic JSON Schema for the basic information commonly stored for a Commercial Registration (CR) entity in a Ministry of Commerce-like system. This is not an official Ministry of Commerce specification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "crNumber",
    "entityNameArabic",
    "legalForm",
    "registrationStatus",
    "registrationDate",
    "entityType"
  ],
  "properties": {
    "crNumber": {
      "type": "string",
      "title": "Commercial Registration Number",
      "description": "Commercial registration number for the entity.",
      "pattern": "^\\d{10}$",
      "minLength": 10,
      "maxLength": 10,
      "examples": ["1010123456"],
      "x-format-note": "Exactly 10 digits."
    },
    "unifiedNumber": {
      "type": "string",
      "title": "Unified Entity Number",
      "description": "Unified number assigned to the business entity, if applicable.",
      "pattern": "^\\d{10}$",
      "minLength": 10,
      "maxLength": 10,
      "examples": ["7001234567"],
      "x-format-note": "Typically 10 digits."
    },
    "entityType": {
      "type": "string",
      "description": "General category of the registered entity.",
      "enum": [
        "establishment",
        "company",
        "branch",
        "professional_entity",
        "foreign_company_branch",
        "other"
      ],
      "examples": ["company"]
    },
    "legalForm": {
      "type": "string",
      "description": "Legal form of the CR entity.",
      "enum": [
        "sole_proprietorship",
        "limited_liability_company",
        "joint_stock_company",
        "simplified_joint_stock_company",
        "general_partnership",
        "limited_partnership",
        "professional_company",
        "branch_of_company",
        "foreign_branch",
        "non_profit_entity",
        "other"
      ],
      "examples": ["limited_liability_company"]
    },
    "entityNameArabic": {
      "type": "string",
      "title": "Entity Name in Arabic",
      "minLength": 2,
      "maxLength": 200,
      "examples": ["شركة التقنية المتقدمة ذات مسؤولية محدودة"]
    },
    "entityNameEnglish": {
      "type": "string",
      "title": "Entity Name in English",
      "minLength": 2,
      "maxLength": 200,
      "examples": ["Advanced Technology Company LLC"]
    },
    "tradeNameArabic": {
      "type": "string",
      "title": "Trade Name in Arabic",
      "minLength": 2,
      "maxLength": 200,
      "examples": ["التقنية المتقدمة"]
    },
    "tradeNameEnglish": {
      "type": "string",
      "title": "Trade Name in English",
      "minLength": 2,
      "maxLength": 200,
      "examples": ["Advanced Tech"]
    },
    "registrationStatus": {
      "type": "string",
      "description": "Current status of the commercial registration.",
      "enum": [
        "active",
        "expired",
        "suspended",
        "cancelled",
        "under_liquidation",
        "closed",
        "unknown"
      ],
      "examples": ["active"]
    },
    "registrationDate": {
      "type": "string",
      "format": "date",
      "description": "Date of initial CR registration.",
      "examples": ["2023-01-15"]
    },
    "expiryDate": {
      "type": "string",
      "format": "date",
      "description": "CR expiry date, if applicable.",
      "examples": ["2028-01-14"]
    },
    "lastRenewalDate": {
      "type": "string",
      "format": "date",
      "description": "Most recent renewal date.",
      "examples": ["2025-01-10"]
    },
    "chamberOfCommerceMembershipNumber": {
      "type": "string",
      "description": "Membership number in the chamber of commerce, if applicable.",
      "pattern": "^\\d{1,20}$",
      "minLength": 1,
      "maxLength": 20,
      "examples": ["123456789"]
    },
    "capitalAmountSar": {
      "type": "number",
      "description": "Declared capital amount in Saudi Riyals.",
      "minimum": 0,
      "maximum": 1000000000000,
      "examples": [500000]
    },
    "capitalCurrency": {
      "type": "string",
      "description": "Currency code for capital amount.",
      "pattern": "^[A-Z]{3}$",
      "minLength": 3,
      "maxLength": 3,
      "examples": ["SAR"]
    },
    "mainActivity": {
      "type": "object",
      "additionalProperties": false,
      "description": "Primary registered business activity.",
      "properties": {
        "activityCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 20,
          "pattern": "^[A-Za-z0-9\\-.]+$",
          "examples": ["620100"]
        },
        "activityNameArabic": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "examples": ["تطوير البرمجيات"]
        },
        "activityNameEnglish": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "examples": ["Software Development"]
        }
      }
    },
    "activities": {
      "type": "array",
      "description": "List of registered entity activities.",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "activityCode",
          "activityNameArabic"
        ],
        "properties": {
          "activityCode": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20,
            "pattern": "^[A-Za-z0-9\\-.]+$",
            "examples": ["620100"]
          },
          "activityNameArabic": {
            "type": "string",
            "minLength": 2,
            "maxLength": 200,
            "examples": ["تطوير البرمجيات"]
          },
          "activityNameEnglish": {
            "type": "string",
            "minLength": 2,
            "maxLength": 200,
            "examples": ["Software Development"]
          },
          "isPrimary": {
            "type": "boolean",
            "examples": [true]
          }
        }
      }
    },
    "contactInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mobileNumber": {
          "type": "string",
          "pattern": "^05\\d{8}$",
          "description": "Saudi mobile number in local format.",
          "examples": ["0551234567"],
          "x-format-note": "10 digits, starts with 05."
        },
        "phoneNumber": {
          "type": "string",
          "description": "Landline or office phone number.",
          "pattern": "^\\d{8,15}$",
          "examples": ["0112345678"]
        },
        "email": {
          "type": "string",
          "format": "email",
          "maxLength": 254,
          "examples": ["info@advancedtech.sa"]
        },
        "websiteUrl": {
          "type": "string",
          "format": "uri",
          "maxLength": 500,
          "examples": ["https://www.advancedtech.sa"]
        }
      }
    },
    "nationalAddress": {
      "type": "object",
      "additionalProperties": false,
      "description": "National address or headquarters address of the entity.",
      "properties": {
        "region": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "examples": ["Riyadh Region"]
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "examples": ["Riyadh"]
        },
        "district": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "examples": ["Al Olaya"]
        },
        "streetName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 150,
          "examples": ["King Fahd Road"]
        },
        "buildingNumber": {
          "type": "string",
          "pattern": "^\\d{4}$",
          "examples": ["1234"],
          "x-format-note": "4 digits."
        },
        "postalCode": {
          "type": "string",
          "pattern": "^\\d{5}$",
          "examples": ["12211"]
        },
        "additionalNumber": {
          "type": "string",
          "pattern": "^\\d{4}$",
          "examples": ["5678"]
        },
        "unitNumber": {
          "type": "string",
          "pattern": "^\\d{1,10}$",
          "examples": ["15"]
        },
        "shortAddress": {
          "type": "string",
          "pattern": "^[A-Z]{4}\\d{4}$",
          "examples": ["ABCD1234"]
        }
      }
    },
    "owners": {
      "type": "array",
      "description": "Owners, shareholders, or partners linked to the entity.",
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ownerType",
          "ownerName"
        ],
        "properties": {
          "ownerType": {
            "type": "string",
            "enum": [
              "individual",
              "company",
              "government",
              "foreign_investor",
              "other"
            ],
            "examples": ["individual"]
          },
          "ownerName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 200,
            "examples": ["Ahmed Mohammed Al-Qahtani"]
          },
          "ownerId": {
            "type": "string",
            "description": "National ID, iqama, or CR number depending on owner type.",
            "pattern": "^(?:[12]\\d{9}|\\d{10})$",
            "minLength": 10,
            "maxLength": 10,
            "examples": ["1023456789", "1010123456"],
            "x-format-note": "10 digits. Individuals often start with 1 or 2; entities may use 10-digit CR."
          },
          "sharePercentage": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "examples": [50]
          }
        }
      }
    },
    "manager": {
      "type": "object",
      "additionalProperties": false,
      "description": "Manager or authorized representative basic information.",
      "properties": {
        "managerName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "examples": ["Faisal Saleh Al-Harbi"]
        },
        "managerId": {
          "type": "string",
          "pattern": "^[12]\\d{9}$",
          "minLength": 10,
          "maxLength": 10,
          "examples": ["1034567890"],
          "x-format-note": "Exactly 10 digits, starts with 1 or 2."
        },
        "managerRole": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "examples": ["General Manager"]
        }
      }
    },
    "branchInfo": {
      "type": "object",
      "additionalProperties": false,
      "description": "Branch-specific details if the CR belongs to a branch.",
      "properties": {
        "isBranch": {
          "type": "boolean",
          "examples": [false]
        },
        "parentCrNumber": {
          "type": "string",
          "pattern": "^\\d{10}$",
          "minLength": 10,
          "maxLength": 10,
          "examples": ["1010123400"]
        },
        "branchNameArabic": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "examples": ["فرع الرياض"]
        },
        "branchSequenceNumber": {
          "type": "integer",
          "minimum": 1,
          "maximum": 999999,
          "examples": [1]
        }
      }
    },
    "taxInfo": {
      "type": "object",
      "additionalProperties": false,
      "description": "Basic tax-related identifiers if linked in the business profile.",
      "properties": {
        "vatRegistered": {
          "type": "boolean",
          "examples": [true]
        },
        "vatNumber": {
          "type": "string",
          "pattern": "^3\\d{13}3$",
          "minLength": 15,
          "maxLength": 15,
          "examples": ["300123456700003"],
          "x-format-note": "Common Saudi VAT format: 15 digits starting and ending with 3."
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "examples": ["2023-01-15T08:30:00Z"]
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "examples": ["2026-03-07T10:15:00Z"]
    }
  }
}