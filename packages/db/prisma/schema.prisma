// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Organization (MOC Commercial Registration aligned) ───────────────────────

model Organization {
  id                  String               @id @default(cuid())
  name                String
  nameArabic          String?              // Official entity name in Arabic
  nameEnglish         String?              // Official entity name in English
  tradeNameArabic     String?              // Trade name in Arabic
  tradeNameEnglish    String?              // Trade name in English
  crNumber            String?              @unique // Commercial Registration Number (10 digits)
  unifiedNumber       String?              @unique // Unified entity number (10 digits)
  vatNumber           String?              @unique // VAT number (15 digits, starts/ends with 3)
  type                OrgType              @default(DEVELOPER)
  entityType          EntityType?          // MOC: establishment, company, branch, etc.
  legalForm           LegalForm?           // MOC: LLC, JSC, sole proprietorship, etc.
  registrationStatus  RegistrationStatus?  // MOC: active, expired, suspended, etc.
  registrationDate    DateTime?            // CR registration date
  expiryDate          DateTime?            // CR expiry date
  capitalAmountSar    Decimal?             // Declared capital in SAR
  mainActivityCode    String?              // ISIC activity code
  mainActivityNameAr  String?              // Primary activity name (Arabic)
  contactInfo         Json?                // {mobileNumber, phoneNumber, email, websiteUrl}
  nationalAddress     Json?                // Saudi national address object
  managerInfo         Json?                // {managerName, managerId, managerRole}
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  users               User[]
  units               Unit[]              @relation("UnitOrganization")
  customers           Customer[]
  documents           Document[]
  maintenanceRequests MaintenanceRequest[]
  preventivePlans     PreventiveMaintenancePlan[]
  permissionRequests  PermissionRequest[]
  supportTickets      SupportTicket[]
  invitations         Invitation[]
  joinRequests        JoinRequest[]    @relation("OrgJoinRequests")

  // ── Commercialization relations ──
  subscriptions         Subscription[]
  entitlementOverrides  EntitlementOverride[]
  paymentMethods        PaymentMethod[]
  invoices              Invoice[]
  couponRedemptions     CouponRedemption[]
}

enum OrgType {
  BROKERAGE
  PROPERTY_MANAGEMENT
  DEVELOPER
  MIXED
}

enum EntityType {
  ESTABLISHMENT
  COMPANY
  BRANCH
  PROFESSIONAL_ENTITY
  FOREIGN_COMPANY_BRANCH
  OTHER_ENTITY
}

enum LegalForm {
  SOLE_PROPRIETORSHIP
  LIMITED_LIABILITY_COMPANY
  JOINT_STOCK_COMPANY
  SIMPLIFIED_JOINT_STOCK_COMPANY
  GENERAL_PARTNERSHIP
  LIMITED_PARTNERSHIP
  PROFESSIONAL_COMPANY
  BRANCH_OF_COMPANY
  FOREIGN_BRANCH
  NON_PROFIT_ENTITY
  OTHER_LEGAL_FORM
}

enum RegistrationStatus {
  ACTIVE_REG
  EXPIRED_REG
  SUSPENDED_REG
  CANCELLED_REG
  UNDER_LIQUIDATION
  CLOSED_REG
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  name                  String?
  password              String
  role                  UserRole             @default(USER)
  organizationId        String
  organization          Organization         @relation(fields: [organizationId], references: [id])
  accountType           String?              // "individual" | "company"
  onboardingCompleted   Boolean              @default(false)
  invitedBy             String?              // userId of the person who invited this user
  invitedVia            String?              // "registration" | "invitation" | "direct" | "join_request"
  customers             Customer[]           @relation("AssignedCustomers")
  assignedMaintenance   MaintenanceRequest[] @relation("AssignedMaintenance")
  preferences           Json?
  resetTokens           PasswordResetToken[]
  notifications         Notification[]
  permissionRequests    PermissionRequest[]  @relation("PermissionRequests")
  reviewedRequests      PermissionRequest[]  @relation("ReviewedRequests")
  supportTickets        SupportTicket[]      @relation("SupportTickets")
  assignedTickets       SupportTicket[]      @relation("AssignedTickets")
  ticketMessages        TicketMessage[]      @relation("TicketMessages")
  sentInvitations       Invitation[]         @relation("SentInvitations")
  receivedInvitation    Invitation?          @relation("ReceivedInvitation")
  joinRequests          JoinRequest[]        @relation("UserJoinRequests")
  reviewedJoinRequests  JoinRequest[]        @relation("JoinReviewers")
  customerActivities  CustomerActivity[]   @relation("ActivityCreator")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([organizationId])
}

enum UserRole {
  SYSTEM_ADMIN
  SYSTEM_SUPPORT
  ADMIN
  MANAGER
  AGENT
  TECHNICIAN
  USER
}

// ─── Unit ─────────────────────────────────────────────────────────────────────

model Unit {
  id         String     @id @default(cuid())
  number     String
  type       UnitType
  status     UnitStatus @default(AVAILABLE)
  organizationId  String
  organization    Organization  @relation("UnitOrganization", fields: [organizationId], references: [id])
  area         Float?        // sqm
  price        Decimal?      // Base/cost price
  markupPrice  Decimal?      // Selling price (for sale/reservation)
  rentalPrice  Decimal?      // Rental price (for lease contracts)
  floor        Int?          // Floor number
  buildingName    String?
  addressLine     String?
  city            String?
  district        String?
  bedrooms     Int?          // Number of bedrooms
  bathrooms    Int?          // Number of bathrooms
  commercialStrategy CommercialStrategy? // FR-08/21: SELL, LEASE, HOLD, etc.
  reservations        Reservation[]
  documents           Document[]
  contracts           Contract[]
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  preventivePlans     PreventiveMaintenancePlan[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([organizationId])
}

// ─── Customer (Absher individual data aligned) ────────────────────────────────

model Customer {
  id             String        @id @default(cuid())
  name           String
  nameArabic     String?       // Full name in Arabic
  email          String?
  phone          String
  nationalId     String?       // Saudi ID / Iqama (10 digits, starts with 1 or 2)
  personType     PersonType?   // saudi_citizen, resident, gcc_citizen, etc.
  gender         Gender?
  dateOfBirth    DateTime?     // Gregorian DOB
  dateOfBirthHijri String?    // Hijri date as text (e.g. 1410-10-19)
  nationality    String?       // e.g. "Saudi Arabian"
  nationalityCode String?     // ISO code e.g. "SA"
  maritalStatus  String?       // single, married, divorced, widowed
  address        Json?         // National address {region, city, district, streetName, buildingNumber, postalCode, additionalNumber, shortAddress}
  documentInfo   Json?         // ID document {documentType, documentNumber, issueDate, expiryDate, issuingAuthority}
  nationalIdHash String?       // SHA-256 hash for exact search on encrypted nationalId
  phoneHash      String?       // SHA-256 hash for exact search on encrypted phone
  emailHash      String?       // SHA-256 hash for exact search on encrypted email
  // RED: Buyer profile enhancements
  preferredLanguage    String?  @default("ar")
  authorizedSignatory  String?   // For corporate buyers
  companyDocuments     Json?     // For corporate buyers
  status               CustomerStatus @default(NEW)
  source               String?
  budget               Decimal?       // Customer's budget in SAR
  propertyTypeInterest String?        // e.g. "APARTMENT", "VILLA", "OFFICE"
  lostReason           String?        // Reason for LOST status
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  agentId        String?
  agent          User?         @relation("AssignedCustomers", fields: [agentId], references: [id])
  reservations   Reservation[]
  contracts      Contract[]
  leases         Lease[]
  documents      Document[]
  activities     CustomerActivity[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([agentId])
  @@index([nationalId])
}

enum PersonType {
  SAUDI_CITIZEN
  RESIDENT
  GCC_CITIZEN
  VISITOR
  OTHER_PERSON
}

enum Gender {
  MALE
  FEMALE
}

enum CustomerStatus {
  NEW
  CONTACTED
  INTERESTED
  QUALIFIED
  VIEWING
  NEGOTIATION
  RESERVED
  CONVERTED
  LOST
  ACTIVE_TENANT
  PAST_TENANT
}

// ─── Reservation ──────────────────────────────────────────────────────────────

model Reservation {
  id              String            @id @default(cuid())
  customerId      String
  customer        Customer          @relation(fields: [customerId], references: [id])
  unitId          String
  unit            Unit              @relation(fields: [unitId], references: [id])
  userId          String?           // The agent/user who created the reservation
  status          ReservationStatus @default(PENDING)
  expiresAt       DateTime
  amount          Decimal?
  // RED: Enhanced reservation fields
  depositRequired  Boolean  @default(false)
  depositAmount    Decimal?
  depositPaidAt    DateTime?
  extensions       ReservationExtension[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([customerId])
  @@index([unitId])
  @@index([userId])
}

// RED: Reservation extension requests
model ReservationExtension {
  id              String   @id @default(cuid())
  reservationId   String
  reservation     Reservation @relation(fields: [reservationId], references: [id])
  requestedBy     String
  approvedBy      String?
  newExpiresAt    DateTime
  reason          String?
  status          ExtensionStatus @default(PENDING_EXTENSION)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([reservationId])
}

enum ExtensionStatus {
  PENDING_EXTENSION
  APPROVED_EXTENSION
  REJECTED_EXTENSION
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
}

// ─── Contract ─────────────────────────────────────────────────────────────────

model Contract {
  id         String         @id @default(cuid())
  customerId String
  customer   Customer       @relation(fields: [customerId], references: [id])
  unitId     String
  unit       Unit           @relation(fields: [unitId], references: [id])
  userId     String?        // The agent/user who created the contract
  status     ContractStatus @default(DRAFT)
  type       ContractType   @default(SALE)
  fileUrl    String?
  amount     Decimal
  signedAt   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // Contract identification
  contractNumber            String?         @unique

  // Lease link (type=LEASE only)
  leaseId                   String?         @unique
  lease                     Lease?          @relation(fields: [leaseId], references: [id])

  // Ejar fields (type=LEASE)
  paymentFrequency          RecurrenceType?
  securityDeposit           Decimal?
  autoRenewal               Boolean?
  maintenanceResponsibility String?         // "LANDLORD" or "TENANT"
  noticePeriodDays          Int?

  // Sale fields (type=SALE)
  deliveryDate              DateTime?

  // Shared
  termsAndConditions        String?
  notes                     String?
  // RED: Amount breakdown
  grossAmount               Decimal?
  discountAmount            Decimal?
  netAmount                 Decimal?
  // RED: Template & signatures
  templateId                String?
  templateVersion           Int?
  buyerSignedAt             DateTime?
  buyerSignatureUrl         String?
  pdfPreviewUrl             String?
  // RED: Relations
  paymentPlan               PaymentPlan?

  @@index([customerId])
  @@index([unitId])
  @@index([userId])
  @@index([leaseId])
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  CANCELLED
  VOID
}

enum ContractType {
  SALE
  LEASE
}

// RED: Payment Plans (linked 1:1 to Contract)
model PaymentPlan {
  id             String   @id @default(cuid())
  contractId     String   @unique
  contract       Contract @relation(fields: [contractId], references: [id])
  name           String?
  totalAmount    Decimal
  downPayment    Decimal?
  status         PaymentPlanStatus @default(DRAFT_PLAN)
  installments   PaymentPlanInstallment[]
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum PaymentPlanStatus {
  DRAFT_PLAN
  ACTIVE_PLAN
  COMPLETED_PLAN
  CANCELLED_PLAN
}

model PaymentPlanInstallment {
  id                String   @id @default(cuid())
  paymentPlanId     String
  paymentPlan       PaymentPlan @relation(fields: [paymentPlanId], references: [id])
  installmentNumber Int
  amount            Decimal
  dueDate           DateTime
  status            InstallmentStatus @default(UNPAID)
  paidAt            DateTime?
  paidAmount        Decimal?
  paymentMethod     String?
  referenceNumber   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([paymentPlanId])
}

enum InstallmentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

// RED: Contract Templates
model ContractTemplate {
  id             String   @id @default(cuid())
  name           String
  nameArabic     String?
  type           ContractType
  version        Int      @default(1)
  content        String   // HTML template with {{vars}}
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

enum UnitType {
  APARTMENT
  VILLA
  OFFICE
  RETAIL
  WAREHOUSE
  PARKING
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  SOLD
  RENTED
  MAINTENANCE
  SUSPENDED        // RED: temporarily blocked from transactions
  WITHDRAWN        // RED: permanently removed from inventory
  HANDED_OVER      // RED: handover to buyer completed
}

// ─── Lease ────────────────────────────────────────────────────────────────────

model Lease {
  id             String          @id @default(cuid())
  unitId         String
  unit           Unit            @relation(fields: [unitId], references: [id])
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id])
  startDate      DateTime
  endDate        DateTime
  totalAmount    Decimal
  status         LeaseStatus     @default(DRAFT)
  installments   RentInstallment[]
  ejarContractId String?         // For Ejar integration
  contract       Contract?       // Linked contract (reverse relation)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([unitId])
  @@index([customerId])
}

enum LeaseStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  EXPIRED
  TERMINATED
}

// ─── Rent Installment ─────────────────────────────────────────────────────────

model RentInstallment {
  id          String            @id @default(cuid())
  leaseId     String
  lease       Lease             @relation(fields: [leaseId], references: [id])
  dueDate     DateTime
  amount      Decimal
  status      PaymentStatus     @default(UNPAID)
  paidAt      DateTime?
  paymentMethod String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([leaseId])
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

// ─── Document ─────────────────────────────────────────────────────────────────

model Document {
  id             String       @id @default(cuid())
  name           String
  url            String
  type           String       // file extension or mime type
  category       DocCategory  @default(GENERAL)
  size           Int?         // in bytes
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id])
  unitId         String?
  unit           Unit?        @relation(fields: [unitId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String?
  version        Int          @default(1)
  versions       DocumentVersion[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([customerId])
  @@index([unitId])
  @@index([organizationId])
}

enum DocCategory {
  GENERAL
  LEGAL
  CONTRACT
  MARKETING
  FINANCE
}

// ─── Maintenance Request ──────────────────────────────────────────────────────

model MaintenanceRequest {
  id             String               @id @default(cuid())
  title          String
  description    String?
  type           String?              // Legacy field (electrical, plumbing, etc.)
  category       MaintenanceCategory  @default(GENERAL)
  status         MaintenanceStatus    @default(OPEN)
  priority       MaintenancePriority  @default(MEDIUM)
  unitId         String
  unit           Unit                 @relation(fields: [unitId], references: [id])
  assignedToId   String?
  assignedTo     User?                @relation("AssignedMaintenance", fields: [assignedToId], references: [id])

  // Scheduling & deadlines
  scheduledDate  DateTime?
  dueDate        DateTime?
  completedAt    DateTime?

  // Cost tracking
  estimatedCost  Decimal?
  actualCost     Decimal?
  laborHours     Float?

  // Work order notes
  notes          String?

  // Preventive maintenance link
  isPreventive       Boolean           @default(false)
  preventivePlanId   String?
  preventivePlan     PreventiveMaintenancePlan? @relation(fields: [preventivePlanId], references: [id])

  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  resolvedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([organizationId])
  @@index([unitId])
  @@index([assignedToId])
  @@index([preventivePlanId])
  @@index([status])
  @@index([dueDate])
  @@index([category])
}

// ─── Preventive Maintenance Plan ──────────────────────────────────────────────

model PreventiveMaintenancePlan {
  id                 String              @id @default(cuid())
  title              String
  description        String?
  category           MaintenanceCategory @default(GENERAL)
  priority           MaintenancePriority @default(MEDIUM)

  // Scope
  unitId             String?
  unit               Unit?               @relation(fields: [unitId], references: [id])

  // Recurrence
  recurrenceType     RecurrenceType
  recurrenceInterval Int                 @default(1)
  startDate          DateTime
  endDate            DateTime?
  nextRunDate        DateTime

  // Cost estimation
  estimatedCost      Decimal?
  estimatedHours     Float?

  // Assignment
  assignToId         String?

  // Status
  isActive           Boolean             @default(true)

  // Organization
  organizationId     String
  organization       Organization        @relation(fields: [organizationId], references: [id])

  // Generated work orders
  workOrders         MaintenanceRequest[]

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([organizationId])
  @@index([nextRunDate])
  @@index([isActive])
}

enum MaintenanceStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceCategory {
  HVAC
  PLUMBING
  ELECTRICAL
  STRUCTURAL
  FIRE_SAFETY
  ELEVATOR
  CLEANING
  LANDSCAPING
  PEST_CONTROL
  GENERAL
}

enum RecurrenceType {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

// ─── Password Reset Token (NIST SP 800-63B) ─────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

// ─── Audit Log (PDPL Article 32 compliance) ────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  userId         String
  userEmail      String
  userRole       String
  action         String   // CREATE, READ, UPDATE, DELETE, READ_PII, EXPORT, LOGIN, LOGOUT
  resource       String   // Customer, Contract, Unit, etc.
  resourceId     String?
  metadata       Json?
  changeSnapshot Json?    // RED: {before: {...}, after: {...}} for UPDATE, full payload for CREATE
  fieldChanges   Json?    // RED: [{field, oldValue, newValue}, ...] auto-computed diff
  ipAddress      String?
  organizationId String
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([resource, action])
}

// ─── Commercial Strategy (FR-08/21) ─────────────────────────────────────────

enum CommercialStrategy {
  SELL
  LEASE
  HOLD
  TRANSFER
  COMMUNITY
}

// ─── Notification (FR-45) ───────────────────────────────────────────────────

model Notification {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  type           String   // PAYMENT_DUE, PAYMENT_OVERDUE, LEASE_EXPIRY, MAINTENANCE_UPDATE
  title          String
  titleEn        String?
  message        String
  messageEn      String?
  link           String?
  read           Boolean  @default(false)
  organizationId String
  createdAt      DateTime @default(now())

  @@index([userId, read])
  @@index([organizationId])
}

// ─── Permission Request (Help Dashboard) ────────────────────────────────────

model PermissionRequest {
  id                    String        @id @default(cuid())
  userId                String
  user                  User          @relation("PermissionRequests", fields: [userId], references: [id])
  requestedRole         UserRole?
  reason                String
  status                RequestStatus @default(PENDING)
  reviewedBy            String?
  reviewer              User?         @relation("ReviewedRequests", fields: [reviewedBy], references: [id])
  reviewNote            String?
  organizationId        String
  organization          Organization  @relation(fields: [organizationId], references: [id])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([status])
}

enum RequestStatus {
  PENDING
  APPROVED
  DECLINED
}

// ─── Support Ticket (Help Dashboard) ────────────────────────────────────────

model SupportTicket {
  id              String         @id @default(cuid())
  ticketNumber    String         @unique
  userId          String
  user            User           @relation("SupportTickets", fields: [userId], references: [id])
  subject         String
  description     String
  category        TicketCategory
  priority        TicketPriority @default(MEDIUM)
  status          TicketStatus   @default(OPEN)
  assignedTo      String?
  assignee        User?          @relation("AssignedTickets", fields: [assignedTo], references: [id])
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  messages        TicketMessage[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id           String        @id @default(cuid())
  ticketId     String
  ticket       SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation("TicketMessages", fields: [userId], references: [id])
  message      String
  isStaffReply Boolean       @default(false)
  createdAt    DateTime      @default(now())

  @@index([ticketId])
}

enum TicketCategory {
  BUG_REPORT
  FEATURE_REQUEST
  ACCOUNT_ISSUE
  BILLING
  TECHNICAL_SUPPORT
  GENERAL_INQUIRY
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  RESOLVED
  CLOSED
}

// ─── Invitation (Token-based team invitations) ────────────────────────────────

model Invitation {
  id              String           @id @default(cuid())
  email           String
  token           String           @unique
  role            UserRole         @default(USER)
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id])
  invitedById     String
  invitedBy       User             @relation("SentInvitations", fields: [invitedById], references: [id])
  acceptedById    String?          @unique
  acceptedBy      User?            @relation("ReceivedInvitation", fields: [acceptedById], references: [id])
  status          InvitationStatus @default(PENDING_INVITE)
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime         @default(now())

  @@unique([email, organizationId])
  @@index([token])
  @@index([organizationId])
}

enum InvitationStatus {
  PENDING_INVITE
  ACCEPTED_INVITE
  EXPIRED_INVITE
  REVOKED_INVITE
}

// ─── Join Request (CR-based org discovery) ─────────────────────────────────────

model JoinRequest {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation("UserJoinRequests", fields: [userId], references: [id])
  targetOrgId     String
  targetOrg       Organization      @relation("OrgJoinRequests", fields: [targetOrgId], references: [id])
  crNumber        String            // CR number used for lookup
  reason          String?           // Optional message from requester
  status          JoinRequestStatus @default(PENDING_JOIN)
  reviewedById    String?
  reviewedBy      User?             @relation("JoinReviewers", fields: [reviewedById], references: [id])
  reviewNote      String?
  reviewedAt      DateTime?
  expiresAt       DateTime          // createdAt + 14 days
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([userId, targetOrgId, status])
  @@index([userId])
  @@index([targetOrgId])
  @@index([status])
}

enum JoinRequestStatus {
  PENDING_JOIN
  APPROVED_JOIN
  DECLINED_JOIN
  EXPIRED_JOIN
  CANCELLED_JOIN
}

// ─── Document Version ────────────────────────────────────────────────────────

model DocumentVersion {
  id            String   @id @default(cuid())
  documentId    String
  document      Document @relation(fields: [documentId], references: [id])
  versionNumber Int
  url           String
  size          Int?
  uploadedBy    String?
  changeNote    String?
  createdAt     DateTime @default(now())

  @@index([documentId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMMERCIALIZATION LAYER — Plans, Subscriptions, Payments, Invoicing
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Enums ───────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  UNPAID
  PAUSED
  CANCELED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum EntitlementType {
  BOOLEAN    // Feature on/off (e.g., cmms.access)
  LIMIT      // Numeric cap (e.g., projects.max = 25)
  METERED    // Usage-based tracking (future)
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELED
  REFUNDED
}

enum ZatcaStatus {
  NOT_APPLICABLE
  PENDING
  CLEARED
  REPORTED
  REJECTED
}

enum TransactionStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

enum CouponType {
  PERCENTAGE    // e.g., 20% off
  FIXED_AMOUNT  // e.g., 100 SAR off
}

// ─── Plan (commercial package definition) ────────────────────────────────────

model Plan {
  id               String            @id @default(cuid())
  slug             String            @unique  // "starter", "professional", "enterprise"
  nameEn           String                     // Display name (English)
  nameAr           String                     // Display name (Arabic)
  descriptionEn    String?
  descriptionAr    String?
  priceMonthly     Decimal           @default(0) // SAR per month
  priceAnnual      Decimal           @default(0) // SAR per year (discounted)
  currency         String            @default("SAR")
  trialDays        Int               @default(14)
  isPublic         Boolean           @default(true)  // Visible on pricing page
  isDefault        Boolean           @default(false) // Assigned to new orgs
  sortOrder        Int               @default(0)
  features         Json?             // Marketing feature list for pricing page
  metadata         Json?             // Additional config (e.g., SLA tier, support channel)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  entitlements     PlanEntitlement[]
  subscriptions    Subscription[]
  coupons          Coupon[]          @relation("CouponPlans")

  @@index([isPublic, sortOrder])
}

// ─── Plan Entitlement (feature/limit per plan) ──────────────────────────────

model PlanEntitlement {
  id          String          @id @default(cuid())
  planId      String
  plan        Plan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureKey  String          // e.g., "projects.max", "cmms.access", "reports.export"
  type        EntitlementType
  value       String          // "true"/"false" for BOOLEAN, numeric string for LIMIT/METERED
  metadata    Json?           // Additional context (e.g., description, display label)

  @@unique([planId, featureKey])
  @@index([featureKey])
}

// ─── Subscription (org enrollment in a plan) ────────────────────────────────

model Subscription {
  id                  String             @id @default(cuid())
  organizationId      String
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId              String
  plan                Plan               @relation(fields: [planId], references: [id])
  status              SubscriptionStatus @default(TRIALING)
  billingCycle        BillingCycle       @default(MONTHLY)
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  trialEndsAt         DateTime?
  canceledAt          DateTime?
  cancelReason        String?
  pausedAt            DateTime?
  resumesAt           DateTime?
  nextBillingDate     DateTime?
  priceAtRenewal      Decimal?           // Locked-in price for next renewal
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  events              SubscriptionEvent[]
  invoices            Invoice[]

  @@index([organizationId])
  @@index([status])
  @@index([currentPeriodEnd])
}

// ─── Subscription Event (audit trail for status transitions) ────────────────

model SubscriptionEvent {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  fromStatus      SubscriptionStatus?
  toStatus        SubscriptionStatus
  triggeredBy     String       // "system", "webhook", "admin:<userId>", "user:<userId>"
  reason          String?
  metadata        Json?        // Additional context (e.g., gateway response, dunning attempt #)
  createdAt       DateTime     @default(now())

  @@index([subscriptionId])
  @@index([createdAt])
}

// ─── Entitlement Override (per-org exceptions for enterprise/custom deals) ──

model EntitlementOverride {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  featureKey      String
  type            EntitlementType
  value           String
  reason          String?         // Why this override exists (e.g., "Enterprise contract #123")
  grantedBy       String?         // userId of admin who granted
  expiresAt       DateTime?       // Null = permanent
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([organizationId, featureKey])
  @@index([organizationId])
}

// ─── Invoice ────────────────────────────────────────────────────────────────

model Invoice {
  id               String        @id @default(cuid())
  invoiceNumber    String        @unique  // Sequential per ZATCA (e.g., INV-2026-00001)
  uuid             String        @unique @default(uuid()) // UUID v4 per ZATCA
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id])
  subscriptionId   String?
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])
  status           InvoiceStatus @default(DRAFT)
  billingCycle     BillingCycle?
  subtotal         Decimal       // Before VAT
  vatRate          Decimal       @default(0.15) // 15% Saudi VAT
  vatAmount        Decimal
  discountAmount   Decimal       @default(0)
  total            Decimal       // subtotal + vatAmount - discountAmount
  currency         String        @default("SAR")
  issuedAt         DateTime?
  dueDate          DateTime?
  paidAt           DateTime?
  notes            String?

  // ZATCA e-invoicing fields
  zatcaStatus      ZatcaStatus   @default(NOT_APPLICABLE)
  zatcaHash        String?       // Previous invoice hash (for chaining)
  zatcaQrCode      String?       // Base64 encoded QR
  xmlContent       String?       // Signed ZATCA XML
  zatcaSubmittedAt DateTime?
  zatcaClearedAt   DateTime?

  couponId         String?
  coupon           Coupon?       @relation(fields: [couponId], references: [id])

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  lineItems        InvoiceLineItem[]
  transactions     PaymentTransaction[]

  @@index([organizationId])
  @@index([status])
  @@index([issuedAt])
  @@index([invoiceNumber])
}

// ─── Invoice Line Item ──────────────────────────────────────────────────────

model InvoiceLineItem {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description   String
  descriptionAr String?
  quantity      Int      @default(1)
  unitPrice     Decimal
  vatRate       Decimal  @default(0.15)
  vatAmount     Decimal
  total         Decimal  // quantity * unitPrice + vatAmount
  sortOrder     Int      @default(0)

  @@index([invoiceId])
}

// ─── Payment Transaction ────────────────────────────────────────────────────

model PaymentTransaction {
  id              String        @id @default(cuid())
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  gateway         String        // "moyasar", "hyperpay", "paytabs"
  gatewayRef      String?       // Gateway-specific transaction ID
  amount          Decimal
  currency        String        @default("SAR")
  status          TransactionStatus @default(PENDING)
  failureReason   String?
  refundedAmount  Decimal?
  metadata        Json?         // Raw gateway response
  initiatedAt     DateTime      @default(now())
  completedAt     DateTime?

  @@index([invoiceId])
  @@index([gatewayRef])
  @@index([status])
}

// ─── Payment Method (tokenized card per org) ────────────────────────────────

model PaymentMethod {
  id              String               @id @default(cuid())
  organizationId  String
  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gateway         String               // "moyasar", "hyperpay"
  tokenId         String               // Gateway token reference
  brand           String?              // "mada", "visa", "mastercard", "applepay"
  lastFourDigits  String?
  expiryMonth     Int?
  expiryYear      Int?
  holderName      String?
  isDefault       Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  transactions    PaymentTransaction[]

  @@index([organizationId])
}

// ─── Gateway Config (system-level gateway credentials) ──────────────────────

model GatewayConfig {
  id             String   @id @default(cuid())
  gateway        String   @unique // "moyasar", "hyperpay", "paytabs"
  displayName    String
  isEnabled      Boolean  @default(false)
  isPrimary      Boolean  @default(false)
  supportedBrands Json?   // ["mada", "visa", "mastercard", "applepay"]
  config         Json?    // Non-secret config (e.g., mode: "test"/"live")
  // Secret keys stored in env vars, NOT here
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Webhook Event (idempotency log) ────────────────────────────────────────

model WebhookEvent {
  id           String   @id @default(cuid())
  gateway      String   // "moyasar", "hyperpay", "paytabs"
  eventId      String   // Gateway event ID (for idempotency)
  eventType    String   // e.g., "payment.succeeded", "payment.failed"
  payload      Json     // Raw webhook payload
  processedAt  DateTime?
  error        String?  // Processing error message if failed
  createdAt    DateTime @default(now())

  @@unique([gateway, eventId])
  @@index([gateway, eventType])
  @@index([createdAt])
}

// ─── Coupon (code-based discount) ───────────────────────────────────────────

model Coupon {
  id              String           @id @default(cuid())
  code            String           @unique
  descriptionEn   String?
  descriptionAr   String?
  type            CouponType
  value           Decimal          // Percentage (0-100) or fixed SAR amount
  currency        String           @default("SAR")
  maxRedemptions  Int?             // Null = unlimited
  currentUses     Int              @default(0)
  validFrom       DateTime         @default(now())
  validUntil      DateTime?
  isActive        Boolean          @default(true)
  minPurchaseAmount Decimal?       // Minimum invoice amount
  applicableCycles  Json?          // ["MONTHLY", "ANNUAL"] or null = all
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  plans           Plan[]           @relation("CouponPlans")
  redemptions     CouponRedemption[]
  invoices        Invoice[]

  @@index([code])
  @@index([isActive, validFrom, validUntil])
}

// ─── Coupon Redemption (usage tracking per org) ─────────────────────────────

model CouponRedemption {
  id              String       @id @default(cuid())
  couponId        String
  coupon          Coupon       @relation(fields: [couponId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  discountApplied Decimal      // Actual SAR discount given
  redeemedAt      DateTime     @default(now())

  @@index([couponId])
  @@index([organizationId])
}

// ─── Customer Activity Timeline (CRM) ─────────────────────────────────────────

model CustomerActivity {
  id           String       @id @default(cuid())
  customerId   String
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type         ActivityType
  note         String
  createdById  String
  createdBy    User         @relation("ActivityCreator", fields: [createdById], references: [id])
  createdAt    DateTime     @default(now())

  @@index([customerId])
  @@index([createdById])
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  SITE_VISIT
  NOTE
  WHATSAPP
}
