// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Organization (MOC Commercial Registration aligned) ───────────────────────

model Organization {
  id                  String               @id @default(cuid())
  name                String
  nameArabic          String?              // Official entity name in Arabic
  nameEnglish         String?              // Official entity name in English
  tradeNameArabic     String?              // Trade name in Arabic
  tradeNameEnglish    String?              // Trade name in English
  crNumber            String?              @unique // Commercial Registration Number (10 digits)
  unifiedNumber       String?              @unique // Unified entity number (10 digits)
  vatNumber           String?              @unique // VAT number (15 digits, starts/ends with 3)
  type                OrgType              @default(DEVELOPER)
  entityType          EntityType?          // MOC: establishment, company, branch, etc.
  legalForm           LegalForm?           // MOC: LLC, JSC, sole proprietorship, etc.
  registrationStatus  RegistrationStatus?  // MOC: active, expired, suspended, etc.
  registrationDate    DateTime?            // CR registration date
  expiryDate          DateTime?            // CR expiry date
  capitalAmountSar    Decimal?             // Declared capital in SAR
  mainActivityCode    String?              // ISIC activity code
  mainActivityNameAr  String?              // Primary activity name (Arabic)
  contactInfo         Json?                // {mobileNumber, phoneNumber, email, websiteUrl}
  nationalAddress     Json?                // Saudi national address object
  managerInfo         Json?                // {managerName, managerId, managerRole}
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  users               User[]
  projects            Project[]
  customers           Customer[]
  documents           Document[]
  maintenanceRequests MaintenanceRequest[]
  preventivePlans     PreventiveMaintenancePlan[]
  permissionRequests  PermissionRequest[]
  supportTickets      SupportTicket[]
  invitations         Invitation[]
  joinRequests        JoinRequest[]    @relation("OrgJoinRequests")

  // ── Commercialization relations ──
  subscriptions         Subscription[]
  entitlementOverrides  EntitlementOverride[]
  paymentMethods        PaymentMethod[]
  invoices              Invoice[]
  couponRedemptions     CouponRedemption[]

  // ── Planning OS relations ──
  planningWorkspaces    PlanningWorkspace[]
}

enum OrgType {
  DEVELOPER
  COMMERCIAL
}

enum EntityType {
  ESTABLISHMENT
  COMPANY
  BRANCH
  PROFESSIONAL_ENTITY
  FOREIGN_COMPANY_BRANCH
  OTHER_ENTITY
}

enum LegalForm {
  SOLE_PROPRIETORSHIP
  LIMITED_LIABILITY_COMPANY
  JOINT_STOCK_COMPANY
  SIMPLIFIED_JOINT_STOCK_COMPANY
  GENERAL_PARTNERSHIP
  LIMITED_PARTNERSHIP
  PROFESSIONAL_COMPANY
  BRANCH_OF_COMPANY
  FOREIGN_BRANCH
  NON_PROFIT_ENTITY
  OTHER_LEGAL_FORM
}

enum RegistrationStatus {
  ACTIVE_REG
  EXPIRED_REG
  SUSPENDED_REG
  CANCELLED_REG
  UNDER_LIQUIDATION
  CLOSED_REG
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  name                  String?
  password              String
  role                  UserRole             @default(USER)
  organizationId        String
  organization          Organization         @relation(fields: [organizationId], references: [id])
  accountType           String?              // "individual" | "company"
  onboardingCompleted   Boolean              @default(false)
  invitedBy             String?              // userId of the person who invited this user
  invitedVia            String?              // "registration" | "invitation" | "direct" | "join_request"
  customers             Customer[]           @relation("AssignedCustomers")
  assignedMaintenance   MaintenanceRequest[] @relation("AssignedMaintenance")
  preferences           Json?
  resetTokens           PasswordResetToken[]
  notifications         Notification[]
  permissionRequests    PermissionRequest[]  @relation("PermissionRequests")
  reviewedRequests      PermissionRequest[]  @relation("ReviewedRequests")
  supportTickets        SupportTicket[]      @relation("SupportTickets")
  assignedTickets       SupportTicket[]      @relation("AssignedTickets")
  ticketMessages        TicketMessage[]      @relation("TicketMessages")
  sentInvitations       Invitation[]         @relation("SentInvitations")
  receivedInvitation    Invitation?          @relation("ReceivedInvitation")
  joinRequests          JoinRequest[]        @relation("UserJoinRequests")
  reviewedJoinRequests  JoinRequest[]        @relation("JoinReviewers")
  // ── Wafi Compliance Relations ──
  engineeringConsultant EngineeringConsultant?
  consultantAssignments ConsultantAssignment[] @relation("ConsultantUser")
  certifiedMilestones   ConstructionMilestone[] @relation("CertifiedBy")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([organizationId])
}

enum UserRole {
  SYSTEM_ADMIN              // Mimaric platform admin — full platform + all org access
  SYSTEM_SUPPORT            // Mimaric support/engineering — ticket management + platform ops
  COMPANY_ADMIN             // Customer organization admin — full org control, no platform access
  PROJECT_MANAGER
  SALES_MANAGER
  SALES_AGENT
  PROPERTY_MANAGER
  FINANCE_OFFICER
  TECHNICIAN
  ENGINEERING_CONSULTANT    // Wafi: independent engineering consultant for milestone certification
  BUYER
  TENANT
  USER
}

// ─── Project (Balady property/land aligned) ───────────────────────────────────

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?
  type           ProjectType
  status         ProjectStatus @default(PLANNING)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  // Balady property fields
  parcelNumber   String?       // Official parcel number
  plotNumber     String?       // Plot in subdivision
  blockNumber    String?       // Block in district
  deedNumber     String?       // Title deed number
  landUse        LandUse?      // Zoning classification
  totalAreaSqm   Float?        // Total land area in sqm
  // Location
  region         String?       // Saudi region (e.g. Riyadh Region)
  city           String?       // City name
  district       String?       // District/neighborhood
  streetName     String?       // Street name
  postalCode     String?       // 5-digit postal code
  latitude       Float?        // GPS latitude
  longitude      Float?        // GPS longitude
  // Optional nested data as JSON
  boundaries     Json?         // {north, south, east, west} descriptions
  utilities      Json?         // {electricityConnected, waterConnected, sewageConnected, roadAccess}
  estimatedValueSar Decimal?   // Property valuation in SAR
  // Land acquisition fields (FR-01, FR-02)
  landOwner         String?    // Current owner name
  landOwnerType     String?    // INDIVIDUAL, COMPANY, GOVERNMENT
  acquisitionPrice  Decimal?   // Purchase price in SAR
  acquisitionDate   DateTime?  // Date of acquisition
  landLegalNotes    String?    // Legal notes / encumbrances
  suitabilityScore Float?       // Weighted feasibility score 0-100
  buildings      Building[]
  documents      Document[]
  dueDiligence   DueDiligence[]
  siteLogs       SiteLog[]
  phases         Phase[]
  constraints          ConstraintRecord[]
  feasibilityAssessments FeasibilityAssessment[]
  decisionGates        DecisionGate[]
  conceptPlans         ConceptPlan[]
  subdivisionPlans     SubdivisionPlan[]
  approvalSubmissions  ApprovalSubmission[]
  infrastructureReadiness InfrastructureReadiness[]
  inventoryItems       InventoryItem[]
  pricingRules         PricingRule[]
  launchWaves          LaunchWave[]
  // ── Wafi Compliance Relations ──
  escrowAccount          EscrowAccount?
  constructionMilestones ConstructionMilestone[]
  consultantAssignments  ConsultantAssignment[]
  wafiContracts          WafiContract[]
  delayPenalties         DelayPenalty[]
  wafiLicense            WafiLicense?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

enum ProjectType {
  RESIDENTIAL
  COMMERCIAL
  MIXED_USE
  VILLA_COMPOUND
}

enum ProjectStatus {
  // Raw Land Phase (Stages 1-3)
  LAND_IDENTIFIED
  LAND_UNDER_REVIEW
  LAND_ACQUIRED
  // Transition (Stage 4)
  CONCEPT_DESIGN
  // Planned Land Phase (Stages 5-8)
  SUBDIVISION_PLANNING
  AUTHORITY_SUBMISSION
  INFRASTRUCTURE_PLANNING
  // Off-Plan Preparation (Stages 9-11)
  INVENTORY_STRUCTURING
  PRICING_PACKAGING
  LAUNCH_READINESS
  // Off-Plan Launch (Stage 12)
  OFF_PLAN_LAUNCHED
  // Existing construction statuses
  PLANNING
  UNDER_CONSTRUCTION
  READY
  HANDED_OVER
}

enum LandUse {
  RESIDENTIAL_LAND
  COMMERCIAL_LAND
  INDUSTRIAL_LAND
  AGRICULTURAL_LAND
  ADMINISTRATIVE_LAND
  PUBLIC_FACILITY
  MIXED_USE_LAND
  OTHER_LAND_USE
}

// ─── Building (Balady building details aligned) ───────────────────────────────

model Building {
  id                String   @id @default(cuid())
  name              String
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id])
  phaseId           String?
  phase             Phase?   @relation(fields: [phaseId], references: [id])
  // Balady building detail fields
  numberOfFloors    Int?     // Total floors
  buildingAreaSqm   Float?   // Built-up area in sqm
  constructionYear  Int?     // Year of construction
  buildingType      String?  // residential, commercial, etc.
  occupancyStatus   String?  // vacant, occupied, under_construction, etc.
  electricityConnected Boolean? // Utility: electricity
  waterConnected    Boolean? // Utility: water
  units             Unit[]
  documents         Document[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([projectId])
  @@index([phaseId])
}

// ─── Unit ─────────────────────────────────────────────────────────────────────

model Unit {
  id         String     @id @default(cuid())
  number     String
  type       UnitType
  status     UnitStatus @default(AVAILABLE)
  buildingId   String
  building     Building      @relation(fields: [buildingId], references: [id])
  area         Float?        // sqm
  price        Decimal?      // Base/cost price
  markupPrice  Decimal?      // Selling price (for sale/reservation)
  rentalPrice  Decimal?      // Rental price (for lease contracts)
  floor        Int?          // Floor number
  bedrooms     Int?          // Number of bedrooms
  bathrooms    Int?          // Number of bathrooms
  commercialStrategy CommercialStrategy? // FR-08/21: SELL, LEASE, HOLD, etc.
  reservations        Reservation[]
  documents           Document[]
  contracts           Contract[]
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  preventivePlans     PreventiveMaintenancePlan[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([buildingId])
}

// ─── Customer (Absher individual data aligned) ────────────────────────────────

model Customer {
  id             String        @id @default(cuid())
  name           String
  nameArabic     String?       // Full name in Arabic
  email          String?
  phone          String
  nationalId     String?       // Saudi ID / Iqama (10 digits, starts with 1 or 2)
  personType     PersonType?   // saudi_citizen, resident, gcc_citizen, etc.
  gender         Gender?
  dateOfBirth    DateTime?     // Gregorian DOB
  dateOfBirthHijri String?    // Hijri date as text (e.g. 1410-10-19)
  nationality    String?       // e.g. "Saudi Arabian"
  nationalityCode String?     // ISO code e.g. "SA"
  maritalStatus  String?       // single, married, divorced, widowed
  address        Json?         // National address {region, city, district, streetName, buildingNumber, postalCode, additionalNumber, shortAddress}
  documentInfo   Json?         // ID document {documentType, documentNumber, issueDate, expiryDate, issuingAuthority}
  nationalIdHash String?       // SHA-256 hash for exact search on encrypted nationalId
  phoneHash      String?       // SHA-256 hash for exact search on encrypted phone
  emailHash      String?       // SHA-256 hash for exact search on encrypted email
  status         CustomerStatus @default(NEW)
  source         String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  agentId        String?
  agent          User?         @relation("AssignedCustomers", fields: [agentId], references: [id])
  reservations   Reservation[]
  contracts      Contract[]
  leases         Lease[]
  documents      Document[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([agentId])
  @@index([nationalId])
}

enum PersonType {
  SAUDI_CITIZEN
  RESIDENT
  GCC_CITIZEN
  VISITOR
  OTHER_PERSON
}

enum Gender {
  MALE
  FEMALE
}

enum CustomerStatus {
  NEW
  INTERESTED
  QUALIFIED
  VIEWING
  RESERVED
  CONVERTED
  LOST
  ACTIVE_TENANT
  PAST_TENANT
}

// ─── Reservation ──────────────────────────────────────────────────────────────

model Reservation {
  id              String            @id @default(cuid())
  customerId      String
  customer        Customer          @relation(fields: [customerId], references: [id])
  unitId          String
  unit            Unit              @relation(fields: [unitId], references: [id])
  userId          String?           // The agent/user who created the reservation
  inventoryItemId String?           // Off-plan inventory link (Phase 3)
  inventoryItem   InventoryItem?    @relation("InventoryReservations", fields: [inventoryItemId], references: [id])
  status          ReservationStatus @default(PENDING)
  expiresAt       DateTime
  amount          Decimal?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([customerId])
  @@index([unitId])
  @@index([userId])
  @@index([inventoryItemId])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
}

// ─── Contract ─────────────────────────────────────────────────────────────────

model Contract {
  id         String         @id @default(cuid())
  customerId String
  customer   Customer       @relation(fields: [customerId], references: [id])
  unitId     String
  unit       Unit           @relation(fields: [unitId], references: [id])
  userId     String?        // The agent/user who created the contract
  status     ContractStatus @default(DRAFT)
  type       ContractType   @default(SALE)
  fileUrl    String?
  amount     Decimal
  signedAt   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // Contract identification
  contractNumber            String?         @unique

  // Lease link (type=LEASE only)
  leaseId                   String?         @unique
  lease                     Lease?          @relation(fields: [leaseId], references: [id])

  // Ejar fields (type=LEASE)
  paymentFrequency          RecurrenceType?
  securityDeposit           Decimal?
  autoRenewal               Boolean?
  maintenanceResponsibility String?         // "LANDLORD" or "TENANT"
  noticePeriodDays          Int?

  // Wafi/Sale fields (type=SALE)
  deliveryDate              DateTime?
  wafiLicenseRef            String?
  escrowAccountRef          String?

  // Shared
  termsAndConditions        String?
  notes                     String?

  @@index([customerId])
  @@index([unitId])
  @@index([userId])
  @@index([leaseId])
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  CANCELLED
  VOID
}

enum ContractType {
  SALE
  LEASE
}

enum UnitType {
  APARTMENT
  VILLA
  OFFICE
  RETAIL
  WAREHOUSE
  PARKING
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  SOLD
  RENTED
  MAINTENANCE
}

// ─── Lease ────────────────────────────────────────────────────────────────────

model Lease {
  id             String          @id @default(cuid())
  unitId         String
  unit           Unit            @relation(fields: [unitId], references: [id])
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id])
  startDate      DateTime
  endDate        DateTime
  totalAmount    Decimal
  status         LeaseStatus     @default(DRAFT)
  installments   RentInstallment[]
  ejarContractId String?         // For Ejar integration
  contract       Contract?       // Linked contract (reverse relation)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([unitId])
  @@index([customerId])
}

enum LeaseStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  EXPIRED
  TERMINATED
}

// ─── Rent Installment ─────────────────────────────────────────────────────────

model RentInstallment {
  id          String            @id @default(cuid())
  leaseId     String
  lease       Lease             @relation(fields: [leaseId], references: [id])
  dueDate     DateTime
  amount      Decimal
  status      PaymentStatus     @default(UNPAID)
  paidAt      DateTime?
  paymentMethod String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([leaseId])
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

// ─── Document ─────────────────────────────────────────────────────────────────

model Document {
  id             String       @id @default(cuid())
  name           String
  url            String
  type           String       // file extension or mime type
  category       DocCategory  @default(GENERAL)
  size           Int?         // in bytes
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id])
  unitId         String?
  unit           Unit?        @relation(fields: [unitId], references: [id])
  buildingId     String?
  building       Building?    @relation(fields: [buildingId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String?
  version        Int          @default(1)
  versions       DocumentVersion[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([projectId])
  @@index([customerId])
  @@index([unitId])
  @@index([buildingId])
  @@index([organizationId])
}

enum DocCategory {
  GENERAL
  BLUEPRINT
  LEGAL
  CONTRACT
  MARKETING
  FINANCE
  GIS
  CAD
  PLANNING
  PERMIT
}

// ─── Maintenance Request ──────────────────────────────────────────────────────

model MaintenanceRequest {
  id             String               @id @default(cuid())
  title          String
  description    String?
  type           String?              // Legacy field (electrical, plumbing, etc.)
  category       MaintenanceCategory  @default(GENERAL)
  status         MaintenanceStatus    @default(OPEN)
  priority       MaintenancePriority  @default(MEDIUM)
  unitId         String
  unit           Unit                 @relation(fields: [unitId], references: [id])
  assignedToId   String?
  assignedTo     User?                @relation("AssignedMaintenance", fields: [assignedToId], references: [id])

  // Scheduling & deadlines
  scheduledDate  DateTime?
  dueDate        DateTime?
  completedAt    DateTime?

  // Cost tracking
  estimatedCost  Decimal?
  actualCost     Decimal?
  laborHours     Float?

  // Work order notes
  notes          String?

  // Preventive maintenance link
  isPreventive       Boolean           @default(false)
  preventivePlanId   String?
  preventivePlan     PreventiveMaintenancePlan? @relation(fields: [preventivePlanId], references: [id])

  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  resolvedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([organizationId])
  @@index([unitId])
  @@index([assignedToId])
  @@index([preventivePlanId])
  @@index([status])
  @@index([dueDate])
  @@index([category])
}

// ─── Preventive Maintenance Plan ──────────────────────────────────────────────

model PreventiveMaintenancePlan {
  id                 String              @id @default(cuid())
  title              String
  description        String?
  category           MaintenanceCategory @default(GENERAL)
  priority           MaintenancePriority @default(MEDIUM)

  // Scope
  unitId             String?
  unit               Unit?               @relation(fields: [unitId], references: [id])
  buildingId         String?

  // Recurrence
  recurrenceType     RecurrenceType
  recurrenceInterval Int                 @default(1)
  startDate          DateTime
  endDate            DateTime?
  nextRunDate        DateTime

  // Cost estimation
  estimatedCost      Decimal?
  estimatedHours     Float?

  // Assignment
  assignToId         String?

  // Status
  isActive           Boolean             @default(true)

  // Organization
  organizationId     String
  organization       Organization        @relation(fields: [organizationId], references: [id])

  // Generated work orders
  workOrders         MaintenanceRequest[]

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([organizationId])
  @@index([nextRunDate])
  @@index([isActive])
}

enum MaintenanceStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceCategory {
  HVAC
  PLUMBING
  ELECTRICAL
  STRUCTURAL
  FIRE_SAFETY
  ELEVATOR
  CLEANING
  LANDSCAPING
  PEST_CONTROL
  GENERAL
}

enum RecurrenceType {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

// ─── Password Reset Token (NIST SP 800-63B) ─────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

// ─── Audit Log (PDPL Article 32 compliance) ────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  userId         String
  userEmail      String
  userRole       String
  action         String   // CREATE, READ, UPDATE, DELETE, READ_PII, EXPORT, LOGIN, LOGOUT
  resource       String   // Customer, Contract, Unit, etc.
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  organizationId String
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([resource, action])
}

// ─── Commercial Strategy (FR-08/21) ─────────────────────────────────────────

enum CommercialStrategy {
  SELL
  LEASE
  HOLD
  TRANSFER
  COMMUNITY
}

// ─── Notification (FR-45) ───────────────────────────────────────────────────

model Notification {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  type           String   // PAYMENT_DUE, PAYMENT_OVERDUE, LEASE_EXPIRY, MAINTENANCE_UPDATE
  title          String
  titleEn        String?
  message        String
  messageEn      String?
  link           String?
  read           Boolean  @default(false)
  organizationId String
  createdAt      DateTime @default(now())

  @@index([userId, read])
  @@index([organizationId])
}

// ─── Due Diligence (FR-03) ──────────────────────────────────────────────────

model DueDiligence {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id])
  category       String    // LEGAL, ZONING, VALUATION, ENVIRONMENTAL, UTILITY
  items          Json      // Array of { label: string, checked: boolean, notes?: string }
  completedAt    DateTime?
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([projectId])
}

// ─── Site Log (FR-17) ───────────────────────────────────────────────────────

model SiteLog {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id])
  date           DateTime
  type           String    // DAILY_LOG, INSPECTION, SNAG, SAFETY, WEATHER
  description    String
  severity       String?   // LOW, MEDIUM, HIGH, CRITICAL
  photos         Json?     // Array of URLs
  resolvedAt     DateTime?
  reportedBy     String?
  organizationId String
  createdAt      DateTime  @default(now())

  @@index([projectId, date])
}

// ─── Phase (FR-07) ──────────────────────────────────────────────────────────

model Phase {
  id             String      @id @default(cuid())
  projectId      String
  project        Project     @relation(fields: [projectId], references: [id])
  name           String
  description    String?
  status         PhaseStatus @default(PLANNING)
  startDate      DateTime?
  endDate        DateTime?
  budgetSar      Decimal?
  buildings      Building[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([projectId])
}

enum PhaseStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

// ─── Permission Request (Help Dashboard) ────────────────────────────────────

model PermissionRequest {
  id                    String        @id @default(cuid())
  userId                String
  user                  User          @relation("PermissionRequests", fields: [userId], references: [id])
  requestedRole         UserRole?
  reason                String
  status                RequestStatus @default(PENDING)
  reviewedBy            String?
  reviewer              User?         @relation("ReviewedRequests", fields: [reviewedBy], references: [id])
  reviewNote            String?
  organizationId        String
  organization          Organization  @relation(fields: [organizationId], references: [id])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([status])
}

enum RequestStatus {
  PENDING
  APPROVED
  DECLINED
}

// ─── Support Ticket (Help Dashboard) ────────────────────────────────────────

model SupportTicket {
  id              String         @id @default(cuid())
  ticketNumber    String         @unique
  userId          String
  user            User           @relation("SupportTickets", fields: [userId], references: [id])
  subject         String
  description     String
  category        TicketCategory
  priority        TicketPriority @default(MEDIUM)
  status          TicketStatus   @default(OPEN)
  assignedTo      String?
  assignee        User?          @relation("AssignedTickets", fields: [assignedTo], references: [id])
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  messages        TicketMessage[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id           String        @id @default(cuid())
  ticketId     String
  ticket       SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation("TicketMessages", fields: [userId], references: [id])
  message      String
  isStaffReply Boolean       @default(false)
  createdAt    DateTime      @default(now())

  @@index([ticketId])
}

enum TicketCategory {
  BUG_REPORT
  FEATURE_REQUEST
  ACCOUNT_ISSUE
  BILLING
  TECHNICAL_SUPPORT
  GENERAL_INQUIRY
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  RESOLVED
  CLOSED
}

// ─── Invitation (Token-based team invitations) ────────────────────────────────

model Invitation {
  id              String           @id @default(cuid())
  email           String
  token           String           @unique
  role            UserRole         @default(USER)
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id])
  invitedById     String
  invitedBy       User             @relation("SentInvitations", fields: [invitedById], references: [id])
  acceptedById    String?          @unique
  acceptedBy      User?            @relation("ReceivedInvitation", fields: [acceptedById], references: [id])
  status          InvitationStatus @default(PENDING_INVITE)
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime         @default(now())

  @@unique([email, organizationId])
  @@index([token])
  @@index([organizationId])
}

enum InvitationStatus {
  PENDING_INVITE
  ACCEPTED_INVITE
  EXPIRED_INVITE
  REVOKED_INVITE
}

// ─── Join Request (CR-based org discovery) ─────────────────────────────────────

model JoinRequest {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation("UserJoinRequests", fields: [userId], references: [id])
  targetOrgId     String
  targetOrg       Organization      @relation("OrgJoinRequests", fields: [targetOrgId], references: [id])
  crNumber        String            // CR number used for lookup
  reason          String?           // Optional message from requester
  status          JoinRequestStatus @default(PENDING_JOIN)
  reviewedById    String?
  reviewedBy      User?             @relation("JoinReviewers", fields: [reviewedById], references: [id])
  reviewNote      String?
  reviewedAt      DateTime?
  expiresAt       DateTime          // createdAt + 14 days
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([userId, targetOrgId, status])
  @@index([userId])
  @@index([targetOrgId])
  @@index([status])
}

enum JoinRequestStatus {
  PENDING_JOIN
  APPROVED_JOIN
  DECLINED_JOIN
  EXPIRED_JOIN
  CANCELLED_JOIN
}

// ═══════════════════════════════════════════════════════════════════════════════
// OFF-PLAN DEVELOPMENT LIFECYCLE (BRD Stages 1-12)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Phase 1: Constraint Record (Stage 2 — Spatial Screening) ────────────────

model ConstraintRecord {
  id             String             @id @default(cuid())
  projectId      String
  project        Project            @relation(fields: [projectId], references: [id])
  type           ConstraintType
  label          String
  labelArabic    String?
  severity       ConstraintSeverity @default(MEDIUM)
  description    String?
  source         String?            // e.g. "Balady Zoning Map", "Municipality Visit"
  mitigationPlan String?
  status         ConstraintStatus   @default(IDENTIFIED)
  metadata       Json?              // Flexible data per constraint type
  organizationId String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([projectId])
}

enum ConstraintType {
  ZONING
  TOPOGRAPHY
  FLOOD_ZONE
  UTILITY_ACCESS
  ENVIRONMENTAL
  ROAD_ACCESS
  SETBACK
  HEIGHT_LIMIT
  HERITAGE
  OTHER_CONSTRAINT
}

enum ConstraintSeverity {
  LOW
  MEDIUM
  HIGH
  BLOCKER
}

enum ConstraintStatus {
  IDENTIFIED
  UNDER_REVIEW
  MITIGATED
  ACCEPTED
  REJECTED
}

// ─── Phase 1: Feasibility Assessment (Stage 3 — Enhanced) ────────────────────

model FeasibilityAssessment {
  id             String          @id @default(cuid())
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id])
  type           FeasibilityType
  score          Float?          // 0-100 suitability score
  recommendation String?         // GO, NO_GO, CONDITIONAL
  assessedBy     String?         // User ID
  assessedAt     DateTime?
  findings       Json?           // Structured findings
  attachmentIds  String[]        // Document IDs
  notes          String?
  organizationId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([projectId])
}

enum FeasibilityType {
  LEGAL
  COMMERCIAL
  TECHNICAL
  ENVIRONMENTAL_FEASIBILITY
  FINANCIAL
}

// ─── Phase 1: Decision Gate (Stage Gates — Formal Approvals) ─────────────────

model DecisionGate {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id])
  fromStage      String       // e.g. "LAND_UNDER_REVIEW"
  toStage        String       // e.g. "LAND_ACQUIRED"
  decision       GateDecision @default(PENDING)
  decidedBy      String?      // User ID
  decidedAt      DateTime?
  conditions     Json?        // Array of conditions that must be met
  notes          String?
  organizationId String
  createdAt      DateTime     @default(now())

  @@index([projectId])
}

enum GateDecision {
  PENDING
  APPROVED
  REJECTED
  DEFERRED
}

// ─── Phase 1: Document Version ───────────────────────────────────────────────

model DocumentVersion {
  id            String   @id @default(cuid())
  documentId    String
  document      Document @relation(fields: [documentId], references: [id])
  versionNumber Int
  url           String
  size          Int?
  uploadedBy    String?
  changeNote    String?
  createdAt     DateTime @default(now())

  @@index([documentId])
}

// ─── Phase 2: Concept Plan (Stage 4 — Development Concept) ──────────────────

model ConceptPlan {
  id                 String            @id @default(cuid())
  projectId          String
  project            Project           @relation(fields: [projectId], references: [id])
  name               String
  nameArabic         String?
  version            Int               @default(1)
  isSelected         Boolean           @default(false)
  description        String?
  totalPlots         Int?
  totalGfaSqm        Float?
  farRatio           Float?            // Floor Area Ratio
  densityUnitsPerHa  Float?
  openSpacePct       Float?
  roadNetworkSummary Json?             // {primaryRoads, secondaryRoads, totalRoadArea}
  amenities          Json?             // [{type, area, count}]
  attachmentDocIds   String[]
  status             ConceptPlanStatus @default(DRAFT)
  createdBy          String?
  organizationId     String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([projectId])
}

enum ConceptPlanStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
}

// ─── Phase 2: Subdivision Plan (Stage 5 — Detailed Planning) ─────────────────

model SubdivisionPlan {
  id                 String                @id @default(cuid())
  projectId          String
  project            Project               @relation(fields: [projectId], references: [id])
  version            Int                   @default(1)
  name               String
  nameArabic         String?
  status             SubdivisionPlanStatus @default(DRAFT)
  totalAreaSqm       Float?
  developableAreaSqm Float?
  numberOfPhases     Int?
  plotCount          Int?
  blockCount         Int?
  boundaryGeoJson    Json?                 // GeoJSON polygon (plain JSON for now; FUTURE: PostGIS)
  metadata           Json?
  approvedBy         String?
  approvedAt         DateTime?
  plots              Plot[]
  blocks             Block[]
  roads              Road[]
  utilityCorridors   UtilityCorridor[]
  planningScenario   PlanningScenario?     // Reverse relation to PlanningScenario
  organizationId     String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([projectId])
}

enum SubdivisionPlanStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  SUPERSEDED
}

// ─── Phase 2: Plot (Subdivided Parcels) ──────────────────────────────────────

model Plot {
  id                String    @id @default(cuid())
  subdivisionPlanId String
  subdivisionPlan   SubdivisionPlan @relation(fields: [subdivisionPlanId], references: [id])
  plotNumber        String
  blockId           String?
  block             Block?    @relation(fields: [blockId], references: [id])
  areaSqm           Float?
  landUse           LandUse?
  phase             Int?      // Phase number within subdivision
  dimensions        Json?     // {frontage, depth} in meters
  boundaryGeoJson   Json?     // Polygon coordinates
  status            PlotStatus @default(PLANNED)
  productType       String?   // VILLA, TOWNHOUSE, APARTMENT_BLOCK, COMMERCIAL_LOT
  inventoryItemId   String?   @unique
  inventoryItem     InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  organizationId    String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([subdivisionPlanId])
  @@index([blockId])
}

enum PlotStatus {
  PLANNED
  APPROVED
  AVAILABLE_FOR_SALE
  RESERVED
  SOLD
  HELD
}

// ─── Phase 2: Block (Group of Plots) ─────────────────────────────────────────

model Block {
  id                String          @id @default(cuid())
  subdivisionPlanId String
  subdivisionPlan   SubdivisionPlan @relation(fields: [subdivisionPlanId], references: [id])
  blockNumber       String
  areaSqm           Float?
  landUse           LandUse?
  numberOfPlots     Int?
  boundaryGeoJson   Json?
  plots             Plot[]
  organizationId    String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([subdivisionPlanId])
}

// ─── Phase 2: Road (Subdivision Roads) ───────────────────────────────────────

model Road {
  id                String          @id @default(cuid())
  subdivisionPlanId String
  subdivisionPlan   SubdivisionPlan @relation(fields: [subdivisionPlanId], references: [id])
  name              String?
  type              RoadType
  widthMeters       Float?
  lengthMeters      Float?
  areaSqm           Float?
  lineGeoJson       Json?           // LineString geometry
  organizationId    String
  createdAt         DateTime        @default(now())

  @@index([subdivisionPlanId])
}

enum RoadType {
  PRIMARY
  SECONDARY
  LOCAL
  SERVICE
  CUL_DE_SAC
}

// ─── Phase 2: Utility Corridor ───────────────────────────────────────────────

model UtilityCorridor {
  id                String          @id @default(cuid())
  subdivisionPlanId String
  subdivisionPlan   SubdivisionPlan @relation(fields: [subdivisionPlanId], references: [id])
  name              String?
  utilityType       UtilityType
  widthMeters       Float?
  lengthMeters      Float?
  lineGeoJson       Json?
  organizationId    String
  createdAt         DateTime        @default(now())

  @@index([subdivisionPlanId])
}

enum UtilityType {
  ELECTRICITY
  WATER
  SEWAGE
  TELECOM
  GAS
  STORMWATER
  MULTI
}

// ─── Phase 2: Approval Submission (Stage 7 — Authority Tracking) ─────────────

model ApprovalSubmission {
  id                 String         @id @default(cuid())
  projectId          String
  project            Project        @relation(fields: [projectId], references: [id])
  authority          String         // e.g. "Balady", "MOMRA", "SEC"
  authorityArabic    String?
  type               ApprovalType
  referenceNumber    String?        // External tracking number
  submittedAt        DateTime?
  status             ApprovalStatus @default(DRAFT_APPROVAL)
  documentIds        String[]       // Document IDs included in submission
  responseDate       DateTime?
  responseNotes      String?
  conditions         ApprovalCondition[]
  comments           ApprovalComment[]
  parentSubmissionId String?        // Links to previous submission if resubmission
  revisionNumber     Int            @default(1)
  organizationId     String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([projectId])
}

enum ApprovalType {
  SUBDIVISION_APPROVAL
  BUILDING_PERMIT
  INFRASTRUCTURE_PERMIT
  ENVIRONMENTAL_CLEARANCE
  UTILITY_CONNECTION
  SALES_LICENSE
  OTHER_APPROVAL
}

enum ApprovalStatus {
  DRAFT_APPROVAL
  SUBMITTED
  UNDER_REVIEW_APPROVAL
  APPROVED_WITH_CONDITIONS
  APPROVED_FINAL
  REJECTED_APPROVAL
  RESUBMISSION_REQUIRED
}

// ─── Phase 2: Approval Comment ───────────────────────────────────────────────

model ApprovalComment {
  id           String                  @id @default(cuid())
  submissionId String
  submission   ApprovalSubmission      @relation(fields: [submissionId], references: [id])
  author       String?                 // Authority reviewer name
  comment      String
  type         CommentType             @default(COMMENT)
  status       CommentResolutionStatus @default(OPEN)
  resolvedBy   String?
  resolvedAt   DateTime?
  resolution   String?
  createdAt    DateTime                @default(now())

  @@index([submissionId])
}

enum CommentType {
  COMMENT
  CONDITION
  OBJECTION
  CLARIFICATION
}

enum CommentResolutionStatus {
  OPEN
  IN_PROGRESS_COMMENT
  RESOLVED
  WAIVED
}

// ─── Phase 2: Approval Condition ─────────────────────────────────────────────

model ApprovalCondition {
  id             String             @id @default(cuid())
  submissionId   String
  submission     ApprovalSubmission @relation(fields: [submissionId], references: [id])
  condition      String
  conditionArabic String?
  isMet          Boolean            @default(false)
  metAt          DateTime?
  evidence       String?            // Document ID or URL
  createdAt      DateTime           @default(now())

  @@index([submissionId])
}

// ─── Phase 3: Infrastructure Readiness (Stage 8) ─────────────────────────────

model InfrastructureReadiness {
  id               String      @id @default(cuid())
  projectId        String
  project          Project     @relation(fields: [projectId], references: [id])
  category         InfraCategory
  status           InfraStatus @default(NOT_STARTED)
  readinessScore   Float?      // 0-100
  estimatedCostSar Decimal?
  actualCostSar    Decimal?
  targetDate       DateTime?
  completedDate    DateTime?
  contractor       String?
  notes            String?
  wave             Int?        // Wave/phase number for staged rollout
  checklistItems   Json?       // [{item, checked, notes}]
  organizationId   String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([projectId])
}

enum InfraCategory {
  ELECTRICITY_INFRA
  WATER_INFRA
  SEWAGE_INFRA
  TELECOM_INFRA
  ROADS_INFRA
  STORMWATER_INFRA
  LANDSCAPING_INFRA
  FENCING_INFRA
  SIGNAGE_INFRA
  STREET_LIGHTING
}

enum InfraStatus {
  NOT_STARTED
  DESIGN_PHASE
  TENDERING
  IN_PROGRESS_INFRA
  TESTING
  COMPLETED_INFRA
  DELAYED
}

// ─── Phase 3: Inventory Item (Stage 9 — Productization) ─────────────────────

model InventoryItem {
  id                 String          @id @default(cuid())
  projectId          String
  project            Project         @relation(fields: [projectId], references: [id])
  plot               Plot?
  itemNumber         String          // Inventory reference number
  productType        ProductType
  productLabel       String?         // e.g. "Villa Type A - 300sqm"
  productLabelArabic String?
  areaSqm            Float?
  basePriceSar       Decimal?
  finalPriceSar      Decimal?
  pricePerSqm        Decimal?
  pricingDetails     Json?           // Breakdown of pricing rules applied
  releasePhase       Int?            // Release wave number
  releaseDate        DateTime?
  status             InventoryStatus @default(UNRELEASED)
  channel            SalesChannel?
  reservations       Reservation[]   @relation("InventoryReservations")
  organizationId     String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([projectId])
  @@index([status])
}

enum ProductType {
  VILLA_PLOT
  TOWNHOUSE_PLOT
  DUPLEX_PLOT
  APARTMENT_PLOT
  COMMERCIAL_LOT
  MIXED_USE_LOT
  RAW_LAND_PLOT
}

enum InventoryStatus {
  UNRELEASED
  AVAILABLE_INV
  RESERVED_INV
  SOLD_INV
  HELD_INV
  WITHDRAWN
}

enum SalesChannel {
  DIRECT
  BROKER
  ONLINE
  AUCTION
  VIP
}

// ─── Phase 3: Pricing Rule (Stage 10 — Pricing Engine) ──────────────────────

model PricingRule {
  id             String          @id @default(cuid())
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id])
  name           String
  nameArabic     String?
  type           PricingRuleType
  factor         Float?          // Multiplier (e.g. 1.15 for 15% premium)
  fixedAmountSar Decimal?        // Fixed amount adjustment
  appliesTo      Json?           // {plotNumbers: [], blocks: [], productTypes: [], phases: []}
  condition      Json?           // {minArea, maxArea, landUse, facingDirection}
  priority       Int             @default(0)
  isActive       Boolean         @default(true)
  organizationId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([projectId])
}

enum PricingRuleType {
  BASE_PRICE_PER_SQM
  CORNER_PREMIUM
  PARK_FACING_PREMIUM
  MAIN_ROAD_PREMIUM
  PHASE_PREMIUM
  BLOCK_ADJUSTMENT
  PRODUCT_TYPE_PREMIUM
  CUSTOM_PRICING
}

// ─── Phase 3: Launch Wave (Stage 10-12 — Release Control) ───────────────────

model LaunchWave {
  id             String     @id @default(cuid())
  projectId      String
  project        Project    @relation(fields: [projectId], references: [id])
  waveNumber     Int
  name           String?
  nameArabic     String?
  status         WaveStatus @default(PLANNED)
  plannedDate    DateTime?
  launchedAt     DateTime?
  inventoryCount Int?
  totalValueSar  Decimal?
  channelConfig  Json?      // {direct: 40, broker: 30, online: 30}
  notes          String?
  organizationId String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([projectId])
}

enum WaveStatus {
  PLANNED
  READY_WAVE
  LAUNCHED
  CLOSED_WAVE
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMMERCIALIZATION LAYER — Plans, Subscriptions, Payments, Invoicing
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Enums ───────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  UNPAID
  PAUSED
  CANCELED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum EntitlementType {
  BOOLEAN    // Feature on/off (e.g., cmms.access)
  LIMIT      // Numeric cap (e.g., projects.max = 25)
  METERED    // Usage-based tracking (future)
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELED
  REFUNDED
}

enum ZatcaStatus {
  NOT_APPLICABLE
  PENDING
  CLEARED
  REPORTED
  REJECTED
}

enum TransactionStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

enum CouponType {
  PERCENTAGE    // e.g., 20% off
  FIXED_AMOUNT  // e.g., 100 SAR off
}

// ─── Plan (commercial package definition) ────────────────────────────────────

model Plan {
  id               String            @id @default(cuid())
  slug             String            @unique  // "starter", "professional", "enterprise"
  nameEn           String                     // Display name (English)
  nameAr           String                     // Display name (Arabic)
  descriptionEn    String?
  descriptionAr    String?
  priceMonthly     Decimal           @default(0) // SAR per month
  priceAnnual      Decimal           @default(0) // SAR per year (discounted)
  currency         String            @default("SAR")
  trialDays        Int               @default(14)
  isPublic         Boolean           @default(true)  // Visible on pricing page
  isDefault        Boolean           @default(false) // Assigned to new orgs
  sortOrder        Int               @default(0)
  features         Json?             // Marketing feature list for pricing page
  metadata         Json?             // Additional config (e.g., SLA tier, support channel)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  entitlements     PlanEntitlement[]
  subscriptions    Subscription[]
  coupons          Coupon[]          @relation("CouponPlans")

  @@index([isPublic, sortOrder])
}

// ─── Plan Entitlement (feature/limit per plan) ──────────────────────────────

model PlanEntitlement {
  id          String          @id @default(cuid())
  planId      String
  plan        Plan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureKey  String          // e.g., "projects.max", "cmms.access", "reports.export"
  type        EntitlementType
  value       String          // "true"/"false" for BOOLEAN, numeric string for LIMIT/METERED
  metadata    Json?           // Additional context (e.g., description, display label)

  @@unique([planId, featureKey])
  @@index([featureKey])
}

// ─── Subscription (org enrollment in a plan) ────────────────────────────────

model Subscription {
  id                  String             @id @default(cuid())
  organizationId      String
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId              String
  plan                Plan               @relation(fields: [planId], references: [id])
  status              SubscriptionStatus @default(TRIALING)
  billingCycle        BillingCycle       @default(MONTHLY)
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  trialEndsAt         DateTime?
  canceledAt          DateTime?
  cancelReason        String?
  pausedAt            DateTime?
  resumesAt           DateTime?
  nextBillingDate     DateTime?
  priceAtRenewal      Decimal?           // Locked-in price for next renewal
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  events              SubscriptionEvent[]
  invoices            Invoice[]

  @@index([organizationId])
  @@index([status])
  @@index([currentPeriodEnd])
}

// ─── Subscription Event (audit trail for status transitions) ────────────────

model SubscriptionEvent {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  fromStatus      SubscriptionStatus?
  toStatus        SubscriptionStatus
  triggeredBy     String       // "system", "webhook", "admin:<userId>", "user:<userId>"
  reason          String?
  metadata        Json?        // Additional context (e.g., gateway response, dunning attempt #)
  createdAt       DateTime     @default(now())

  @@index([subscriptionId])
  @@index([createdAt])
}

// ─── Entitlement Override (per-org exceptions for enterprise/custom deals) ──

model EntitlementOverride {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  featureKey      String
  type            EntitlementType
  value           String
  reason          String?         // Why this override exists (e.g., "Enterprise contract #123")
  grantedBy       String?         // userId of admin who granted
  expiresAt       DateTime?       // Null = permanent
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([organizationId, featureKey])
  @@index([organizationId])
}

// ─── Invoice ────────────────────────────────────────────────────────────────

model Invoice {
  id               String        @id @default(cuid())
  invoiceNumber    String        @unique  // Sequential per ZATCA (e.g., INV-2026-00001)
  uuid             String        @unique @default(uuid()) // UUID v4 per ZATCA
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id])
  subscriptionId   String?
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])
  status           InvoiceStatus @default(DRAFT)
  billingCycle     BillingCycle?
  subtotal         Decimal       // Before VAT
  vatRate          Decimal       @default(0.15) // 15% Saudi VAT
  vatAmount        Decimal
  discountAmount   Decimal       @default(0)
  total            Decimal       // subtotal + vatAmount - discountAmount
  currency         String        @default("SAR")
  issuedAt         DateTime?
  dueDate          DateTime?
  paidAt           DateTime?
  notes            String?

  // ZATCA e-invoicing fields
  zatcaStatus      ZatcaStatus   @default(NOT_APPLICABLE)
  zatcaHash        String?       // Previous invoice hash (for chaining)
  zatcaQrCode      String?       // Base64 encoded QR
  xmlContent       String?       // Signed ZATCA XML
  zatcaSubmittedAt DateTime?
  zatcaClearedAt   DateTime?

  couponId         String?
  coupon           Coupon?       @relation(fields: [couponId], references: [id])

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  lineItems        InvoiceLineItem[]
  transactions     PaymentTransaction[]

  @@index([organizationId])
  @@index([status])
  @@index([issuedAt])
  @@index([invoiceNumber])
}

// ─── Invoice Line Item ──────────────────────────────────────────────────────

model InvoiceLineItem {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description   String
  descriptionAr String?
  quantity      Int      @default(1)
  unitPrice     Decimal
  vatRate       Decimal  @default(0.15)
  vatAmount     Decimal
  total         Decimal  // quantity * unitPrice + vatAmount
  sortOrder     Int      @default(0)

  @@index([invoiceId])
}

// ─── Payment Transaction ────────────────────────────────────────────────────

model PaymentTransaction {
  id              String        @id @default(cuid())
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  gateway         String        // "moyasar", "hyperpay", "paytabs"
  gatewayRef      String?       // Gateway-specific transaction ID
  amount          Decimal
  currency        String        @default("SAR")
  status          TransactionStatus @default(PENDING)
  failureReason   String?
  refundedAmount  Decimal?
  metadata        Json?         // Raw gateway response
  initiatedAt     DateTime      @default(now())
  completedAt     DateTime?

  @@index([invoiceId])
  @@index([gatewayRef])
  @@index([status])
}

// ─── Payment Method (tokenized card per org) ────────────────────────────────

model PaymentMethod {
  id              String               @id @default(cuid())
  organizationId  String
  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gateway         String               // "moyasar", "hyperpay"
  tokenId         String               // Gateway token reference
  brand           String?              // "mada", "visa", "mastercard", "applepay"
  lastFourDigits  String?
  expiryMonth     Int?
  expiryYear      Int?
  holderName      String?
  isDefault       Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  transactions    PaymentTransaction[]

  @@index([organizationId])
}

// ─── Gateway Config (system-level gateway credentials) ──────────────────────

model GatewayConfig {
  id             String   @id @default(cuid())
  gateway        String   @unique // "moyasar", "hyperpay", "paytabs"
  displayName    String
  isEnabled      Boolean  @default(false)
  isPrimary      Boolean  @default(false)
  supportedBrands Json?   // ["mada", "visa", "mastercard", "applepay"]
  config         Json?    // Non-secret config (e.g., mode: "test"/"live")
  // Secret keys stored in env vars, NOT here
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Webhook Event (idempotency log) ────────────────────────────────────────

model WebhookEvent {
  id           String   @id @default(cuid())
  gateway      String   // "moyasar", "hyperpay", "paytabs"
  eventId      String   // Gateway event ID (for idempotency)
  eventType    String   // e.g., "payment.succeeded", "payment.failed"
  payload      Json     // Raw webhook payload
  processedAt  DateTime?
  error        String?  // Processing error message if failed
  createdAt    DateTime @default(now())

  @@unique([gateway, eventId])
  @@index([gateway, eventType])
  @@index([createdAt])
}

// ─── Coupon (code-based discount) ───────────────────────────────────────────

model Coupon {
  id              String           @id @default(cuid())
  code            String           @unique
  descriptionEn   String?
  descriptionAr   String?
  type            CouponType
  value           Decimal          // Percentage (0-100) or fixed SAR amount
  currency        String           @default("SAR")
  maxRedemptions  Int?             // Null = unlimited
  currentUses     Int              @default(0)
  validFrom       DateTime         @default(now())
  validUntil      DateTime?
  isActive        Boolean          @default(true)
  minPurchaseAmount Decimal?       // Minimum invoice amount
  applicableCycles  Json?          // ["MONTHLY", "ANNUAL"] or null = all
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  plans           Plan[]           @relation("CouponPlans")
  redemptions     CouponRedemption[]
  invoices        Invoice[]

  @@index([code])
  @@index([isActive, validFrom, validUntil])
}

// ─── Coupon Redemption (usage tracking per org) ─────────────────────────────

model CouponRedemption {
  id              String       @id @default(cuid())
  couponId        String
  coupon          Coupon       @relation(fields: [couponId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  discountApplied Decimal      // Actual SAR discount given
  redeemedAt      DateTime     @default(now())

  @@index([couponId])
  @@index([organizationId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// WAFI COMPLIANCE MODULE — وافي
// Off-plan real estate regulations: escrow, milestones, engineering consultants,
// Wafi contracts, delay penalties, Wafi licensing, and Etmam platform syncing.
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Module 1: Escrow & Bank Integration ────────────────────────────────────

model EscrowAccount {
  id                String          @id @default(cuid())
  projectId         String          @unique
  project           Project         @relation(fields: [projectId], references: [id])
  bankName          String
  bankCode          String?
  accountNumber     String
  ibanNumber        String
  status            EscrowStatus    @default(PENDING_SETUP)
  totalDeposited    Decimal         @default(0)
  totalWithdrawn    Decimal         @default(0)
  currentBalance    Decimal         @default(0)
  retentionAmount   Decimal         @default(0) // 5% post-completion hold
  retentionReleaseDate DateTime?    // 1 year after completion cert
  adminExpenseCap   Decimal?        // 20% of sold unit value
  adminExpenseUsed  Decimal         @default(0)
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  transactions      EscrowTransaction[]

  @@index([projectId])
}

enum EscrowStatus {
  PENDING_SETUP
  ACTIVE
  FROZEN
  CLOSED
}

model EscrowTransaction {
  id              String              @id @default(cuid())
  escrowAccountId String
  escrowAccount   EscrowAccount       @relation(fields: [escrowAccountId], references: [id])
  type            EscrowTxnType
  amount          Decimal
  currency        String              @default("SAR")
  description     String?
  descriptionAr   String?
  milestoneId     String?             // Links to ConstructionMilestone
  engineerCertId  String?             // Engineering cert that authorized
  referenceNumber String?             // Bank reference
  status          EscrowTxnStatus     @default(PENDING)
  processedAt     DateTime?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([escrowAccountId])
  @@index([milestoneId])
  @@index([status])
}

enum EscrowTxnType {
  BUYER_DEPOSIT
  CONTRACTOR_PAYMENT
  ADMIN_EXPENSE
  RETENTION_HOLD
  RETENTION_RELEASE
  REFUND
  BANK_FEE
}

enum EscrowTxnStatus {
  PENDING
  AWAITING_APPROVAL
  APPROVED
  PROCESSED
  REJECTED
  CANCELLED
}

// ─── Module 2: Engineering Consultant Portal ────────────────────────────────

model EngineeringConsultant {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  licenseNumber   String    // SCEC license number
  licenseExpiry   DateTime
  firmName        String?
  firmNameArabic  String?
  firmCrNumber    String?   // Consulting firm CR number
  specialization  String?   // Structural, MEP, etc.
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  assignments     ConsultantAssignment[]

  @@index([licenseNumber])
}

model ConsultantAssignment {
  id            String           @id @default(cuid())
  consultantId  String
  consultant    EngineeringConsultant @relation(fields: [consultantId], references: [id])
  userId        String
  user          User             @relation("ConsultantUser", fields: [userId], references: [id])
  projectId     String
  project       Project          @relation(fields: [projectId], references: [id])
  status        AssignmentStatus @default(ACTIVE)
  assignedAt    DateTime         @default(now())
  completedAt   DateTime?
  revokedAt     DateTime?
  revokedReason String?

  @@unique([consultantId, projectId])
  @@index([projectId])
  @@index([userId])
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  REVOKED
}

// ─── Module 3: Dynamic Milestone Billing ────────────────────────────────────

model ConstructionMilestone {
  id                String            @id @default(cuid())
  projectId         String
  project           Project           @relation(fields: [projectId], references: [id])
  milestoneNumber   Int               // Sequential: 1, 2, 3...
  name              String
  nameArabic        String?
  description       String?
  descriptionArabic String?
  targetPercentage  Float             // e.g. 25 for 25%
  actualPercentage  Float?            // Certified actual
  targetDate        DateTime?
  actualDate        DateTime?
  status            MilestoneStatus   @default(UPCOMING)
  certifiedById     String?           // → User (Engineering Consultant)
  certifiedBy       User?             @relation("CertifiedBy", fields: [certifiedById], references: [id])
  certifiedAt       DateTime?
  evidenceDocIds    String[]          // Document IDs for photos/reports
  paymentPercentage Float?            // % of total price due at milestone
  metadata          Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  billingItems      MilestoneBillingItem[]

  @@unique([projectId, milestoneNumber])
  @@index([projectId])
  @@index([status])
}

enum MilestoneStatus {
  UPCOMING
  IN_PROGRESS
  PENDING_INSPECTION
  CERTIFIED
  OVERDUE
  SKIPPED
}

model MilestoneBillingItem {
  id            String                @id @default(cuid())
  milestoneId   String
  milestone     ConstructionMilestone @relation(fields: [milestoneId], references: [id])
  contractId    String                // Off-plan buyer contract
  customerId    String                // Buyer
  amountDue     Decimal
  currency      String                @default("SAR")
  dueDate       DateTime?             // Set when milestone certified
  paidAt        DateTime?
  status        BillingItemStatus     @default(NOT_YET_DUE)
  referenceNumber String?             // Payment reference
  metadata      Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([milestoneId])
  @@index([contractId])
  @@index([customerId])
  @@index([status])
}

enum BillingItemStatus {
  NOT_YET_DUE
  DUE
  PAID
  OVERDUE
  CANCELLED
}

model WafiContract {
  id                        String    @id @default(cuid())
  contractId                String    @unique  // → existing Contract model
  projectId                 String
  project                   Project   @relation(fields: [projectId], references: [id])
  escrowAccountRef          String?   // IBAN referenced in contract
  handoverDate              DateTime  // Contractual delivery date
  delayCompensationType     String    @default("PERCENTAGE") // PERCENTAGE or FAIR_MARKET_RENT
  delayCompensationRate     Float     @default(2.0)          // Default 2% (land)
  paymentSchedule           Json?     // [{milestoneNumber, percentage, amount}]
  alternativeDeveloperClause Boolean  @default(true) // REGA right to appoint alt developer
  metadata                  Json?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([projectId])
  @@index([contractId])
}

model DelayPenalty {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id])
  contractId      String?   // Optional: specific contract
  penaltyType     String    // PERCENTAGE or FAIR_MARKET_RENT
  rate            Float     // 2% for land, fair market rent for units
  calculatedAmount Decimal?  // Auto-calculated penalty amount
  currency        String    @default("SAR")
  periodStart     DateTime
  periodEnd       DateTime?
  status          String    @default("ACTIVE") // ACTIVE, PAID, WAIVED, DISPUTED
  notes           String?
  notesArabic     String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([projectId])
  @@index([contractId])
  @@index([status])
}

// ─── Module 4: Etmam Platform Syncing ───────────────────────────────────────

model WafiLicense {
  id              String            @id @default(cuid())
  projectId       String            @unique
  project         Project           @relation(fields: [projectId], references: [id])
  licenseNumber   String?           // REGA license number
  regaReference   String?           // REGA reference ID
  developerScore  Int?              // Out of 100 (35 min to qualify)
  registrationFee Decimal?          // SAR 50,000
  status          WafiLicenseStatus @default(NOT_APPLIED)
  appliedAt       DateTime?
  approvedAt      DateTime?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  etmamRegistration EtmamRegistration?

  @@index([projectId])
  @@index([licenseNumber])
}

enum WafiLicenseStatus {
  NOT_APPLIED
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

model EtmamRegistration {
  id                String          @id @default(cuid())
  wafiLicenseId     String          @unique
  wafiLicense       WafiLicense     @relation(fields: [wafiLicenseId], references: [id])
  etmamProjectId    String?         // Etmam platform project ID
  etmamDeveloperId  String?         // Etmam platform developer ID
  registrationStatus EtmamRegStatus @default(NOT_REGISTERED)
  lastSyncAt        DateTime?
  nextSyncDue       DateTime?       // Quarterly schedule
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  syncLogs          EtmamSyncLog[]

  @@index([wafiLicenseId])
}

enum EtmamRegStatus {
  NOT_REGISTERED
  PENDING
  REGISTERED
  SUSPENDED
}

model EtmamSyncLog {
  id                  String              @id @default(cuid())
  etmamRegistrationId String
  etmamRegistration   EtmamRegistration   @relation(fields: [etmamRegistrationId], references: [id])
  syncType            EtmamSyncType
  direction           String              @default("PUSH") // PUSH or PULL
  status              SyncLogStatus       @default(PENDING)
  requestPayload      Json?               // What was sent
  responsePayload     Json?               // What was received
  errorMessage        String?
  startedAt           DateTime            @default(now())
  completedAt         DateTime?
  createdAt           DateTime            @default(now())

  @@index([etmamRegistrationId])
  @@index([syncType])
  @@index([status])
}

enum EtmamSyncType {
  QUARTERLY_ESCROW_STATEMENT
  CONSTRUCTION_PROGRESS
  FINANCIAL_POSITION
  UNIT_SALES_UPDATE
  DEVELOPER_SCORE
  LICENSE_STATUS
  MANUAL_REPORT
}

enum SyncLogStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  CANCELLED
}

// ─── Planning OS Module ─────────────────────────────────────────────────────

model PlanningWorkspace {
  id                String              @id @default(cuid())
  name              String
  nameArabic        String?
  status            PlanningWorkspaceStatus @default(DRAFT)
  description       String?

  // Links to existing records (one or both)
  landRecordId      String?             // Project ID where status is LAND_*
  projectId         String?             // Full project record (post-acquisition)

  // Site metadata carried from land/project
  siteMetadata      Json?               // {totalAreaSqm, region, city, district, latitude, longitude, boundaries}

  // Ownership
  createdBy         String?             // User ID who created
  organizationId    String
  organization      Organization        @relation(fields: [organizationId], references: [id])

  // Children
  scenarios         PlanningScenario[]
  spatialLayers     SpatialLayer[]
  comments          PlanningComment[]

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([organizationId])
  @@index([landRecordId])
  @@index([projectId])
  @@index([status])
}

enum PlanningWorkspaceStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  APPROVED
  ARCHIVED
}

model PlanningScenario {
  id                String              @id @default(cuid())
  name              String
  nameArabic        String?
  version           Int                 @default(1)
  status            PlanningScenarioStatus @default(DRAFT)
  isBaseline        Boolean             @default(false) // Only one per workspace

  // Parent workspace
  workspaceId       String
  workspace         PlanningWorkspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Linked subdivision plan (geometry)
  subdivisionPlanId String?             @unique
  subdivisionPlan   SubdivisionPlan?    @relation(fields: [subdivisionPlanId], references: [id])

  // Feasibility assumptions
  feasibilitySet    FeasibilityAssumptionSet?

  // Compliance results
  complianceResults ComplianceResult[]

  // Cached metrics (auto-calculated from geometry + assumptions)
  metrics           Json?               // {totalArea, sellableArea, nonSellableArea, sellablePct, plotCount, roadArea, openSpaceArea, estimatedRevenue, estimatedCost, estimatedProfit, far, density}

  // Approval tracking
  approvedBy        String?
  approvedAt        DateTime?
  rejectedBy        String?
  rejectedAt        DateTime?
  reviewNotes       String?

  organizationId    String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([workspaceId])
  @@index([organizationId])
  @@index([status])
}

enum PlanningScenarioStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model SpatialLayer {
  id                String              @id @default(cuid())
  name              String
  nameArabic        String?
  type              SpatialLayerType    @default(IMPORTED)
  visible           Boolean             @default(true)
  locked            Boolean             @default(false)
  opacity           Float               @default(1.0)
  style             Json?               // {color, fillColor, fillOpacity, weight, dashArray}
  sourceFile        String?             // Original filename for imports
  geoJson           Json?               // Full FeatureCollection GeoJSON
  featureCount      Int                 @default(0)

  workspaceId       String
  workspace         PlanningWorkspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  organizationId    String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([workspaceId])
  @@index([organizationId])
}

enum SpatialLayerType {
  BOUNDARY
  PARCELS
  ROADS
  ZONES
  UTILITIES
  IMPORTED
  REFERENCE
  TOPOGRAPHY
}

model RuleTemplate {
  id                String              @id @default(cuid())
  name              String
  nameArabic        String?
  description       String?
  category          RuleCategory
  operator          RuleOperator
  value             Float               // Threshold value
  valueTo           Float?              // For BETWEEN operator
  unit              String              // SQM, METERS, RATIO, PERCENT, UNITS_PER_HA
  landUseScope      String[]            // Empty array = all land uses
  regionScope       String?             // null = all regions
  isDefault         Boolean             @default(false) // System template vs org-specific
  isActive          Boolean             @default(true)

  organizationId    String?             // null = system default template
  complianceResults ComplianceResult[]

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([organizationId])
  @@index([category])
}

enum RuleCategory {
  MIN_AREA
  MAX_AREA
  MIN_FRONTAGE
  MAX_FRONTAGE
  MIN_DEPTH
  MAX_DEPTH
  MIN_ROAD_WIDTH
  MAX_FAR
  MIN_SETBACK
  MAX_COVERAGE
  MAX_DENSITY
  MIN_OPEN_SPACE
}

enum RuleOperator {
  MIN
  MAX
  EQUALS
  BETWEEN
}

model ComplianceResult {
  id                String              @id @default(cuid())
  status            ComplianceStatus
  actualValue       Float
  expectedValue     String              // Human-readable threshold (e.g., "≥ 200 sqm")
  featureId         String?             // Reference to specific plot/road ID
  featureType       String?             // PLOT, ROAD, BLOCK, ZONE
  featureLabel      String?             // e.g., "Plot A-01"

  scenarioId        String
  scenario          PlanningScenario    @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  ruleId            String
  rule              RuleTemplate        @relation(fields: [ruleId], references: [id])

  organizationId    String
  createdAt         DateTime            @default(now())

  @@index([scenarioId])
  @@index([ruleId])
  @@index([organizationId])
}

enum ComplianceStatus {
  PASS
  FAIL
  WARNING
}

model FeasibilityAssumptionSet {
  id                  String            @id @default(cuid())
  name                String?
  nameArabic          String?

  // Core assumptions
  landPriceSarPerSqm  Float?
  constructionCostPerSqm Float?
  infrastructureCostTotal Float?
  contingencyPct      Float?            @default(10)
  profitMarginPct     Float?            @default(15)

  // Per-land-use pricing assumptions (JSON map)
  pricingAssumptions  Json?             // {RESIDENTIAL: {pricePerSqm: 3000, density: 25}, COMMERCIAL: {...}}
  costAssumptions     Json?             // {softCosts: 500000, hardCosts: 0, marketingPct: 3}

  // Auto-calculated results cached
  calculatedMetrics   Json?             // {totalRevenue, totalCost, grossProfit, netProfit, roi, breakeven}

  // Parent scenario
  scenarioId          String            @unique
  scenario            PlanningScenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  organizationId      String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([organizationId])
}

model PlanningComment {
  id                String              @id @default(cuid())
  content           String
  authorId          String              // User ID
  authorName        String?
  authorRole        String?

  // Context
  workspaceId       String
  workspace         PlanningWorkspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scenarioId        String?             // If comment is scenario-specific
  featureId         String?             // If comment is on a specific map feature

  // Threading
  parentId          String?
  mentions          String[]            // User IDs mentioned

  organizationId    String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([workspaceId])
  @@index([scenarioId])
  @@index([organizationId])
}
