  "words": [
    "Mimaric",
    "Ejar",
    "ZATCA",
    "REGA",
    "Wafi",
    "Balady",
    "Absher",
    "MOC",
    "Hijri",
    "tashkeel",
    "parcelNumber",
    "deedNumber",
    "crNumber",
    "nationalId",
    "IBAN",
    "SAR",
    "NOI",
    "MTD",
    "YTD",
    "PropTech",
    "PropTechCo",
    "tanstack",
    "cmdk",
    "shadcn",
    "Recharts",
    "turborepo",
    "Supabase",
    "nextauth",
    "monorepo",
    "Opus",
    "Haiku",
    "Sonnet",
    "unstyled",
    "unstaged",
    "upsert",
    "upserted",
    "revalidate",
    "revalidatePath",
    "Prisma",
    "Decimal",
    "dir's",
    "Omar",
    "Alghamdi",
    "Arabic's",
    "PropTech's"
  ],
  "allowCompoundWords": true,
  "flagWords": [
    "Moblie",
    "Calender",
    "Recieve",
    "Adress",
    "Resedential"
  ]
}
