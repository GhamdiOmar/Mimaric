{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    "node_modules",
    ".next",
    ".turbo",
    "dist",
    "build",
    "coverage",
    "docs/design-v2-screenshots",
    "packages/db/prisma/migrations",
    "pnpm-lock.yaml",
    "package-lock.json",
    "**/*.min.js",
    "**/*.svg",
    "**/*.png",
    "**/*.jpg",
    "**/*.ico",
    "**/*.pdf"
